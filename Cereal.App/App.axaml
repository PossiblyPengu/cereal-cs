<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Cereal.App"
             x:Class="Cereal.App.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <FluentTheme/>
    <StyleInclude Source="avares://Cereal.App/Theme/Cereal.Controls.axaml"/>
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Cereal.App/Theme/Cereal.Palette.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon ToolTipText="Cereal Launcher" Command="{x:Static local:App.ShowWindowCommand}">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Open Cereal" Command="{x:Static local:App.ShowWindowCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Quit" Command="{x:Static local:App.QuitCommand}"/>
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>

</Application>
