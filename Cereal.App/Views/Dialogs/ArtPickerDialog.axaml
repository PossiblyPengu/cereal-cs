<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Cereal.App.Views.Dialogs"
        x:Class="Cereal.App.Views.Dialogs.ArtPickerDialog"
        Title="Pick Artwork"
        Width="700" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="500" MinHeight="400"
        Background="#12122a"
        ExtendClientAreaToDecorationsHint="False">

  <Window.Styles>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#1a1a3a"/>
      <Setter Property="BorderBrush" Value="#33aaaaff"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="CornerRadius" Value="20"/>
      <Setter Property="Padding" Value="12,6"/>
    </Style>
    <Style Selector="Button.action">
      <Setter Property="Background" Value="#33aaaaff"/>
      <Setter Property="Foreground" Value="#ccccff"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.action:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#55aaaaff"/>
    </Style>
    <Style Selector="Border.thumb">
      <Setter Property="Background" Value="#1a1a3a"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="ClipToBounds" Value="True"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.thumb:pointerover">
      <Setter Property="Background" Value="#2a2a5a"/>
    </Style>
    <Style Selector="Border.thumb.selected">
      <Setter Property="BorderBrush" Value="#aaaaff"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="20">

    <!-- Search bar -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
      <TextBox Grid.Column="0" x:Name="SearchBox"
               Watermark="Search SteamGridDB…"
               KeyDown="SearchBox_KeyDown"/>
      <Button Grid.Column="1" Classes="action" Content="Search"
              Margin="10,0,0,0" Click="Search_Click"/>
    </Grid>

    <!-- Results grid -->
    <Panel Grid.Row="1">
      <ScrollViewer x:Name="ResultsScroll">
        <ItemsControl x:Name="ResultsList">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="local:ArtResult">
              <Border Classes="thumb" Width="120" Height="160" Margin="6"
                      Tag="{Binding}" Tapped="Thumb_Tapped">
                <Image Source="{Binding Thumb}" Stretch="UniformToFill"/>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- States -->
      <TextBlock x:Name="StatusText"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Foreground="#55ccccff" FontSize="14" IsVisible="True"
                 Text="Enter a game name and press Search"/>

      <TextBlock x:Name="LoadingText"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Foreground="#55ccccff" FontSize="14" IsVisible="False"
                 Text="Searching…"/>
    </Panel>

    <!-- Action buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="10" Margin="0,16,0,0">
      <Button Content="Cancel" Click="Cancel_Click"
              Background="Transparent" Foreground="#88ccccff"
              BorderBrush="#33aaaaff" BorderThickness="1"
              CornerRadius="6" Padding="14,8" Cursor="Hand"/>
      <Button Classes="action" Content="Use selected" Click="Use_Click"
              x:Name="UseButton" IsEnabled="False"/>
    </StackPanel>

  </Grid>
</Window>
