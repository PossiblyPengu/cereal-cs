<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Cereal.App.Views.Dialogs"
        x:Class="Cereal.App.Views.Dialogs.ArtPickerDialog"
        Title="Pick Artwork"
        Width="700" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="500" MinHeight="400"
        Background="{DynamicResource ThemeVoid}"
        ExtendClientAreaToDecorationsHint="False">

  <Window.Styles>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#08ffffff"/>
      <Setter Property="BorderBrush" Value="#14ffffff"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource ThemeAccent}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,7"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeFocusRingColor}"/>
    </Style>
    <Style Selector="Border.thumb">
      <Setter Property="Background" Value="{DynamicResource ThemeCardUp}"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="ClipToBounds" Value="True"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.thumb:pointerover">
      <Setter Property="Background" Value="#1affffff"/>
    </Style>
    <Style Selector="Border.thumb.selected">
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="20">

    <!-- Search bar -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
      <TextBox Grid.Column="0" x:Name="SearchBox"
               Watermark="Search SteamGridDB…"
               AttachedToVisualTree="SearchBox_AttachedToVisualTree"
               KeyDown="SearchBox_KeyDown"/>
      <Button Grid.Column="1" Classes="action" Content="Search"
              Margin="10,0,0,0" Click="Search_Click"/>
    </Grid>

    <!-- Results grid -->
    <Panel Grid.Row="1">
      <ScrollViewer x:Name="ResultsScroll">
        <ItemsControl x:Name="ResultsList">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="local:ArtResult">
              <Border Classes="thumb" Width="120" Height="160" Margin="6"
                      Tag="{Binding}" Tapped="Thumb_Tapped" DoubleTapped="Thumb_DoubleTapped">
                <Image Source="{Binding Thumb}" Stretch="UniformToFill"/>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- States -->
      <TextBlock x:Name="StatusText"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Foreground="{DynamicResource ThemeText3}" FontSize="14" IsVisible="True"
                 Text="Enter a game name and press Search"/>

      <TextBlock x:Name="LoadingText"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Foreground="{DynamicResource ThemeText3}" FontSize="14" IsVisible="False"
                 Text="Searching…"/>
    </Panel>

    <!-- Action buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="10" Margin="0,16,0,0">
      <Button Content="Cancel" Click="Cancel_Click"
              Classes="ghost" Padding="14,8" IsCancel="True"/>
      <Button Classes="action" Content="Use selected" Click="Use_Click"
              x:Name="UseButton" IsEnabled="False" IsDefault="True"/>
    </StackPanel>

  </Grid>
</Window>
