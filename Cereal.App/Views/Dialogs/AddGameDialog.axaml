<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cereal.App.Views.Dialogs.AddGameDialog"
        Title="Add Game"
        Width="520" Height="700"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource ThemeVoid}"
        ExtendClientAreaToDecorationsHint="False">

  <Window.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="#80b0aaa0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="LetterSpacing" Value="0.5"/>
      <Setter Property="Margin" Value="0,12,0,4"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#10ffffff"/>
      <Setter Property="BorderBrush" Value="#18ffffff"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource ThemeAccent}"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="#4dd4a853"/>
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#10ffffff"/>
      <Setter Property="BorderBrush" Value="#18ffffff"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="TextBox.multiline">
      <Setter Property="MinHeight" Value="60"/>
      <Setter Property="AcceptsReturn" Value="True"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="Expander">
      <Setter Property="Foreground" Value="#80b0aaa0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="*,Auto" Margin="20,16">

    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0">

        <!-- Title -->
        <TextBlock x:Name="DialogTitle" Text="Add Game"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeText}" Margin="0,0,0,14"/>

        <!-- Name -->
        <TextBlock Classes="label" Text="GAME NAME"/>
        <TextBox x:Name="NameBox" Watermark="Game title"
                 AttachedToVisualTree="NameBox_AttachedToVisualTree"/>

        <!-- Platform -->
        <TextBlock Classes="label" Text="PLATFORM"/>
        <ComboBox x:Name="PlatformBox" SelectionChanged="PlatformBox_SelectionChanged">
          <ComboBoxItem Content="custom" IsSelected="True"/>
          <ComboBoxItem Content="steam"/>
          <ComboBoxItem Content="epic"/>
          <ComboBoxItem Content="gog"/>
          <ComboBoxItem Content="battlenet"/>
          <ComboBoxItem Content="ea"/>
          <ComboBoxItem Content="ubisoft"/>
          <ComboBoxItem Content="itchio"/>
          <ComboBoxItem Content="xbox"/>
          <ComboBoxItem Content="psn"/>
        </ComboBox>

        <!-- Platform ID (for steam/epic/gog) -->
        <StackPanel x:Name="PlatformIdSection" IsVisible="False">
          <TextBlock Classes="label" Text="PLATFORM ID"/>
          <TextBox x:Name="PlatformIdBox" Watermark="App ID / Game ID"/>
        </StackPanel>

        <!-- Executable (for custom) -->
        <StackPanel x:Name="ExeSection">
          <TextBlock Classes="label" Text="EXECUTABLE"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" x:Name="ExeBox" Watermark="Path to .exe"/>
            <Button Grid.Column="1" Classes="sm" Content="Browse"
                    Margin="8,0,0,0" Click="BrowseExe_Click"/>
          </Grid>
        </StackPanel>

        <!-- Cover image -->
        <TextBlock Classes="label" Text="COVER IMAGE"/>
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBox Grid.Column="0" x:Name="CoverBox" Watermark="URL or file path"
                   TextChanged="CoverBox_TextChanged"/>
          <Button Grid.Column="1" Classes="sm" Content="File"
                  Margin="8,0,4,0" Click="BrowseCover_Click"/>
          <Button Grid.Column="2" Classes="sm" Content="Search"
                  Click="PickArt_Click"/>
        </Grid>

        <!-- Cover preview -->
        <Border Margin="0,8,0,0" Height="140" Background="#08ffffff"
                CornerRadius="6" ClipToBounds="True"
                IsVisible="{Binding ElementName=CoverPreview, Path=IsVisible}">
          <Image x:Name="CoverPreview" Stretch="Uniform" IsVisible="False"/>
        </Border>

        <!-- Notes -->
        <TextBlock Classes="label" Text="NOTES"/>
        <TextBox x:Name="NotesBox" Classes="multiline"
                 Watermark="Personal notes about this game..." MinHeight="52"/>

        <!-- Categories -->
        <TextBlock Classes="label" Text="CATEGORIES"/>
        <TextBox x:Name="CategoriesBox" Watermark="Action, RPG, Multiplayer"/>

        <!-- Metadata section (expandable) -->
        <Expander x:Name="MetaExpander" Header="▸  METADATA — Auto-fill from web"
                  IsExpanded="False" Margin="0,12,0,0">
          <StackPanel Spacing="0" Margin="0,4,0,0">

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
              <Button x:Name="FetchMetaBtn" Classes="sm" Content="Fetch metadata"
                      Click="FetchMeta_Click"/>
              <TextBlock x:Name="FetchMetaStatus" VerticalAlignment="Center"
                         Foreground="#80b0aaa0" FontSize="11"/>
            </StackPanel>

            <TextBlock Classes="label" Text="DESCRIPTION"/>
            <TextBox x:Name="DescBox" Classes="multiline" Watermark="Game description"/>

            <Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
              <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Classes="label" Text="DEVELOPER"/>
                <TextBox x:Name="DevBox" Watermark="Studio"/>
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Classes="label" Text="PUBLISHER"/>
                <TextBox x:Name="PubBox" Watermark="Publisher"/>
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Classes="label" Text="RELEASE DATE"/>
                <TextBox x:Name="ReleaseDateBox" Watermark="e.g. Dec 10, 2020"/>
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Classes="label" Text="METACRITIC"/>
                <TextBox x:Name="MetacriticBox" Watermark="0–100"/>
              </StackPanel>
            </Grid>

            <TextBlock Classes="label" Text="HEADER IMAGE"/>
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBox Grid.Column="0" x:Name="HeaderBox" Watermark="Wide banner URL"
                       TextChanged="HeaderBox_TextChanged"/>
              <Button Grid.Column="1" Classes="sm" Content="File"
                      Margin="8,0,4,0" Click="BrowseHeader_Click"/>
              <Button Grid.Column="2" Classes="sm" Content="Search"
                      Click="PickHeaderArt_Click"/>
            </Grid>

            <!-- Header preview -->
            <Border Margin="0,8,0,0" Height="100" Background="#08ffffff"
                    CornerRadius="6" ClipToBounds="True"
                    IsVisible="{Binding ElementName=HeaderPreview, Path=IsVisible}">
              <Image x:Name="HeaderPreview" Stretch="Uniform" IsVisible="False"/>
            </Border>

            <TextBlock Classes="label" Text="WEBSITE"/>
            <TextBox x:Name="WebsiteBox" Watermark="https://..."/>

          </StackPanel>
        </Expander>

        <TextBlock x:Name="ErrorText" Foreground="#cc6666" FontSize="12"
                   Margin="0,12,0,0" IsVisible="False"/>

      </StackPanel>
    </ScrollViewer>

    <!-- Action buttons -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="10" Margin="0,14,0,0">
      <Button Classes="secondary" Content="Cancel" Click="Cancel_Click" IsCancel="True"/>
      <Button x:Name="SaveBtn" Classes="action" Content="Add Game" Click="Save_Click" IsDefault="True"/>
    </StackPanel>

  </Grid>
</Window>
