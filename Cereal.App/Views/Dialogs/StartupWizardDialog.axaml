<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cereal.App.ViewModels"
        x:Class="Cereal.App.Views.Dialogs.StartupWizardDialog"
        x:DataType="vm:StartupWizardViewModel"
        Title="Welcome to Cereal"
        Width="640" Height="600"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="False"
        Background="{DynamicResource ThemeVoid}">

  <Window.Styles>
    <StyleInclude Source="avares://Cereal.App/Theme/StartupWizard.Styles.axaml"/>
    <Style Selector="ToggleSwitch.pp">
      <Setter Property="OnContent" Value=""/>
      <Setter Property="OffContent" Value=""/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto">

    <StackPanel Grid.Row="0">
      <ProgressBar Classes="wizard-progress" Maximum="100" Value="{Binding ProgressPercent}"/>
      <Border Classes="wizard-top">
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
          <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
            <TextBlock Text="{Binding StepTitle}" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeText}"/>
            <TextBlock Text="{Binding StepSubtitle}" FontSize="12"
                       Foreground="{DynamicResource ThemeText3}" TextWrapping="Wrap" MaxWidth="520"/>
          </StackPanel>
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StepIndicator}"
                     FontSize="11" Foreground="{DynamicResource ThemeText4}"
                     VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,8,0,0"/>
        </Grid>
      </Border>
    </StackPanel>

    <!-- Step content -->
    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Margin="24,10,24,4">
      <Panel>

        <!-- Step 0: Welcome -->
        <StackPanel IsVisible="{Binding Step, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=0}"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14">
          <Panel Width="56" Height="56" HorizontalAlignment="Center">
            <Ellipse Width="50" Height="50" Stroke="{DynamicResource ThemeAccent}" StrokeThickness="2.4"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Ellipse Width="8" Height="8" Fill="{DynamicResource ThemeAccent}"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14,16,0,0"/>
            <Ellipse Width="6" Height="6" Fill="{DynamicResource ThemeAccent}"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0" Opacity="0.7"/>
            <Ellipse Width="9" Height="9" Fill="{DynamicResource ThemeAccent}"
                     HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Ellipse Width="7" Height="7" Fill="{DynamicResource ThemeAccent}"
                     HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12" Opacity="0.8"/>
          </Panel>
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4,0,0">
            <Border Grid.Row="0" Grid.Column="0" Classes="wizard-card-hi" Padding="10,8" Margin="0,0,6,6">
              <StackPanel Spacing="3">
                <TextBlock Text="Unified Library" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                <TextBlock Text="Steam, Epic, GOG and local titles in one place." FontSize="10" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="0" Grid.Column="1" Classes="wizard-card-hi" Padding="10,8" Margin="6,0,0,6">
              <StackPanel Spacing="3">
                <TextBlock Text="Smart Metadata" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                <TextBlock Text="Auto-cover art, details, and library cleanup." FontSize="10" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="1" Grid.Column="0" Classes="wizard-card-hi" Padding="10,8" Margin="0,6,6,0">
              <StackPanel Spacing="3">
                <TextBlock Text="Remote Play" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                <TextBlock Text="PlayStation streaming with in-app session tabs." FontSize="10" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="1" Grid.Column="1" Classes="wizard-card-hi" Padding="10,8" Margin="6,6,0,0">
              <StackPanel Spacing="3">
                <TextBlock Text="Controller Ready" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                <TextBlock Text="Navigate cards, focus views, and tabs with gamepad." FontSize="10" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="2" Grid.Column="0" Classes="wizard-card-hi" Padding="10,8" Margin="0,6,6,0">
              <StackPanel Spacing="3">
                <TextBlock Text="Discord + Media" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                <TextBlock Text="Rich Presence and now-playing widget support." FontSize="10" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="2" Grid.Column="1" Classes="wizard-card-hi" Padding="10,8" Margin="6,6,0,0">
              <StackPanel Spacing="3">
                <TextBlock Text="Fast + Private" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                <TextBlock Text="Local-first data, secure tokens, and fast virtualized library." FontSize="10" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </Grid>
          <Border Classes="wizard-card-hi" Padding="10,8" MaxWidth="420">
            <StackPanel Spacing="2">
              <TextBlock Text="Performance profile" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
              <TextBlock Text="{Binding PerformanceRecommendation}" FontSize="10" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Step 1: Appearance -->
        <StackPanel IsVisible="{Binding Step, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=1}"
                    VerticalAlignment="Center" Spacing="16">
          <StackPanel Spacing="6">
            <TextBlock Classes="wizard-caps" Text="THEME"/>
            <ItemsControl ItemsSource="{Binding ThemeSwatches}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ThemeSwatchViewModel">
                  <Button Classes="chip" Margin="0,0,8,8"
                          Content="{Binding Label}"
                          Command="{Binding $parent[Window].((vm:StartupWizardViewModel)DataContext).SelectThemeCommand}"
                          CommandParameter="{Binding Id}"
                          Classes.active="{Binding IsActive}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="wizard-caps" Text="ACCENT COLOR"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0" Text="{Binding AccentColor}" Watermark="#d4a853"
                       Background="#10ffffff" BorderBrush="#18ffffff"
                       Foreground="{DynamicResource ThemeText}" CornerRadius="8" Padding="12,8"/>
              <Button Grid.Column="1" Classes="ghost" Content="Reset" Margin="8,0,0,0"
                      Command="{Binding ResetAccentColorCommand}"/>
            </Grid>
          </StackPanel>

          <TextBlock Classes="wizard-caps" Text="DEFAULT VIEW"/>
          <StackPanel Spacing="10">
            <Border Classes="wizard-view-pick"
                    Background="{Binding DefaultView, Converter={x:Static vm:WizardStepConverter.ViewCard}, ConverterParameter=orbit}"
                    PointerPressed="SelectOrbit_Click">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Width="14" Height="14" Foreground="{DynamicResource ThemeText}"
                            Data="M12,12 m-3,0 a3,3 0 1 0 6,0 a3,3 0 1 0 -6,0 M12,12 m-9,0 a9,9 0 1 0 18,0 a9,9 0 1 0 -18,0"/>
                  <TextBlock Text="Orbit" FontSize="14" FontWeight="SemiBold"
                             Foreground="{DynamicResource ThemeText}"/>
                </StackPanel>
                <TextBlock Text="Interactive galaxy with zoom &amp; pan"
                           FontSize="11" Foreground="{DynamicResource ThemeText2}"/>
              </StackPanel>
            </Border>
            <Border Classes="wizard-view-pick"
                    Background="{Binding DefaultView, Converter={x:Static vm:WizardStepConverter.ViewCard}, ConverterParameter=cards}"
                    PointerPressed="SelectCards_Click">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Width="14" Height="14" Foreground="{DynamicResource ThemeText}"
                            Data="M3,3 H10 V10 H3 Z M14,3 H21 V10 H14 Z M3,14 H10 V21 H3 Z M14,14 H21 V21 H14 Z"/>
                  <TextBlock Text="Cards" FontSize="14" FontWeight="SemiBold"
                             Foreground="{DynamicResource ThemeText}"/>
                </StackPanel>
                <TextBlock Text="Classic grid for quick browsing"
                           FontSize="11" Foreground="{DynamicResource ThemeText2}"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </StackPanel>

        <!-- Step 2: Performance & Layout -->
        <StackPanel IsVisible="{Binding Step, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=2}"
                    VerticalAlignment="Top" Spacing="16">
          <Border Classes="wizard-card-hi" Padding="10,8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{Binding PerformanceRecommendation}" FontSize="11" Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding HardwareTier, StringFormat='Detected hardware: {0}'}" FontSize="10" Foreground="{DynamicResource ThemeText2}"/>
              </StackPanel>
              <Button Grid.Column="1" Classes="ghost" Content="Use recommended"
                      Command="{Binding ApplyRecommendedPerformanceCommand}" Padding="10,6"/>
            </Grid>
          </Border>

          <StackPanel Spacing="6">
            <TextBlock Classes="wizard-caps" Text="STAR DENSITY"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="chip" Content="Low"    Click="Density_Low"
                      Classes.active="{Binding StarDensity, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=low}"/>
              <Button Classes="chip" Content="Normal" Click="Density_Normal"
                      Classes.active="{Binding StarDensity, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=normal}"/>
              <Button Classes="chip" Content="High"   Click="Density_High"
                      Classes.active="{Binding StarDensity, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=high}"/>
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="wizard-caps" Text="UI SCALE"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="chip" Content="90%"  Click="Scale_90"
                      Classes.active="{Binding UiScale, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=90%}"/>
              <Button Classes="chip" Content="100%" Click="Scale_100"
                      Classes.active="{Binding UiScale, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=100%}"/>
              <Button Classes="chip" Content="110%" Click="Scale_110"
                      Classes.active="{Binding UiScale, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=110%}"/>
              <Button Classes="chip" Content="125%" Click="Scale_125"
                      Classes.active="{Binding UiScale, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=125%}"/>
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="wizard-caps" Text="TOOLBAR POSITION"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="chip" Content="Top"    Click="Toolbar_Top"
                      Classes.active="{Binding ToolbarPosition, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=top}"/>
              <Button Classes="chip" Content="Bottom" Click="Toolbar_Bottom"
                      Classes.active="{Binding ToolbarPosition, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=bottom}"/>
              <Button Classes="chip" Content="Left"   Click="Toolbar_Left"
                      Classes.active="{Binding ToolbarPosition, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=left}"/>
              <Button Classes="chip" Content="Right"  Click="Toolbar_Right"
                      Classes.active="{Binding ToolbarPosition, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=right}"/>
            </StackPanel>
          </StackPanel>

          <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="Animations" FontSize="13" Foreground="{DynamicResource ThemeText}"/>
              <TextBlock Text="Orbit drift and UI transitions."
                         FontSize="11" Foreground="{DynamicResource ThemeText2}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" Classes="pp" IsChecked="{Binding ShowAnimations}"/>
          </Grid>
        </StackPanel>

        <!-- Step 3: Connect Accounts -->
        <StackPanel IsVisible="{Binding Step, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=3}"
                    VerticalAlignment="Top" Spacing="12">
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" >
            <Border Grid.Row="0" Grid.Column="0" Classes="wizard-card-hi" Padding="12,10" Margin="0,0,6,6">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                  <TextBlock Text="Steam" FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="Import via OpenID + Web API" FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                    <Border Name="SteamAvatarWrap" Width="18" Height="18" CornerRadius="9" Background="#18ffffff" IsVisible="False">
                      <Image Name="SteamAvatar" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Name="SteamStatus" Text="Not connected" FontSize="11" Foreground="{DynamicResource ThemeText2}"/>
                  </StackPanel>
                  <TextBlock Name="SteamMeta" FontSize="10" Foreground="{DynamicResource ThemeText3}"/>
                </StackPanel>
                <Button Grid.Column="1" Name="SteamAuthBtn" Classes="ghost" Content="Sign in"
                        Click="AuthSteam_Click" Padding="12,6"/>
              </Grid>
            </Border>
            <Border Grid.Row="0" Grid.Column="1" Classes="wizard-card-hi" Padding="12,10" Margin="6,0,0,6">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                  <TextBlock Text="GOG" FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="OAuth2 sign-in" FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                    <Border Name="GogAvatarWrap" Width="18" Height="18" CornerRadius="9" Background="#18ffffff" IsVisible="False">
                      <Image Name="GogAvatar" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Name="GogStatus" Text="Not connected" FontSize="11" Foreground="{DynamicResource ThemeText2}"/>
                  </StackPanel>
                  <TextBlock Name="GogMeta" FontSize="10" Foreground="{DynamicResource ThemeText3}"/>
                </StackPanel>
                <Button Grid.Column="1" Name="GogAuthBtn" Classes="ghost" Content="Sign in"
                        Click="AuthGog_Click" Padding="12,6"/>
              </Grid>
            </Border>
            <Border Grid.Row="1" Grid.Column="0" Classes="wizard-card-hi" Padding="12,10" Margin="0,6,6,0">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                  <TextBlock Text="Epic Games" FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="OAuth2 sign-in" FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                    <Border Name="EpicAvatarWrap" Width="18" Height="18" CornerRadius="9" Background="#18ffffff" IsVisible="False">
                      <Image Name="EpicAvatar" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Name="EpicStatus" Text="Not connected" FontSize="11" Foreground="{DynamicResource ThemeText2}"/>
                  </StackPanel>
                  <TextBlock Name="EpicMeta" FontSize="10" Foreground="{DynamicResource ThemeText3}"/>
                </StackPanel>
                <Button Grid.Column="1" Name="EpicAuthBtn" Classes="ghost" Content="Sign in"
                        Click="AuthEpic_Click" Padding="12,6"/>
              </Grid>
            </Border>
            <Border Grid.Row="1" Grid.Column="1" Classes="wizard-card-hi" Padding="12,10" Margin="6,6,0,0">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                  <TextBlock Text="Xbox" FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="Microsoft account sign-in" FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                    <Border Name="XboxAvatarWrap" Width="18" Height="18" CornerRadius="9" Background="#18ffffff" IsVisible="False">
                      <Image Name="XboxAvatar" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Name="XboxStatus" Text="Not connected" FontSize="11" Foreground="{DynamicResource ThemeText2}"/>
                  </StackPanel>
                  <TextBlock Name="XboxMeta" FontSize="10" Foreground="{DynamicResource ThemeText3}"/>
                </StackPanel>
                <Button Grid.Column="1" Name="XboxAuthBtn" Classes="ghost" Content="Sign in"
                        Click="AuthXbox_Click" Padding="12,6"/>
              </Grid>
            </Border>
          </Grid>

          <TextBlock Text="{Binding $parent[Window].((vm:StartupWizardViewModel)DataContext).Step, StringFormat=' '}"
                     FontSize="1" Opacity="0"/>
          <TextBlock Name="AuthStatus" FontSize="11" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>

          <StackPanel Name="SteamApiKeyPanel" IsVisible="False" Spacing="6" Margin="0,4,0,0">
            <TextBlock Text="Your profile may be private. Enter a Steam Web API key to import your library:"
                       FontSize="11" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0" Name="SteamApiKeyBox" Watermark="Steam Web API key" PasswordChar="•"/>
              <Button Grid.Column="1" Classes="sm" Content="Retry" Margin="8,0,0,0"
                      Click="RetrySteamApiKey_Click"/>
            </Grid>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
            <PathIcon Width="12" Height="12" Foreground="{DynamicResource ThemeText3}"
                      Data="M6,10 V7 A4,4 0 0 1 14,7 V10 M7,10 H13 A2,2 0 0 1 15,12 V17 A2,2 0 0 1 13,19 H7 A2,2 0 0 1 5,17 V12 A2,2 0 0 1 7,10 Z"/>
            <TextBlock Text="Your library stays local — Cereal never uploads your account info."
                       FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
          </StackPanel>
        </StackPanel>

        <!-- Step 4: Behavior -->
        <StackPanel IsVisible="{Binding Step, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=4}"
                    VerticalAlignment="Top" Spacing="14">
          <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <StackPanel Grid.Column="0">
              <TextBlock Text="Minimize on game launch" FontSize="13" Foreground="{DynamicResource ThemeText}"/>
              <TextBlock Text="Hide Cereal's window when you start a game."
                         FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" Classes="pp" IsChecked="{Binding MinimizeOnLaunch}"/>
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock Text="Close to system tray" FontSize="13" Foreground="{DynamicResource ThemeText}"/>
              <TextBlock Text="Keep running in the background when you close the window."
                         FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" Classes="pp" IsChecked="{Binding CloseToTray}"/>
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock Text="Discord rich presence" FontSize="13" Foreground="{DynamicResource ThemeText}"/>
              <TextBlock Text="Show what you're playing on your Discord profile."
                         FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" Classes="pp" IsChecked="{Binding DiscordPresence}"/>
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock Text="Auto-sync playtime" FontSize="13" Foreground="{DynamicResource ThemeText}"/>
              <TextBlock Text="Sync Steam playtime data when Cereal starts."
                         FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" Classes="pp" IsChecked="{Binding AutoSyncPlaytime}"/>
          </Grid>

          <Border Classes="wizard-card" Padding="12" Margin="0,4,0,0">
            <StackPanel Spacing="8">
              <TextBlock Text="Quick Reference" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource ThemeText2}"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                    ColumnSpacing="10" RowSpacing="5">
                <Border Grid.Row="0" Grid.Column="0" Classes="wizard-kbd">
                  <TextBlock Text="Ctrl+K" FontSize="11" FontFamily="Consolas,Courier New,monospace"
                             Foreground="{DynamicResource ThemeText}"/>
                </Border>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Open search"
                           FontSize="11" Foreground="{DynamicResource ThemeText2}" VerticalAlignment="Center"/>
                <Border Grid.Row="1" Grid.Column="0" Classes="wizard-kbd">
                  <TextBlock Text="Ctrl+," FontSize="11" FontFamily="Consolas,Courier New,monospace"
                             Foreground="{DynamicResource ThemeText}"/>
                </Border>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Open settings"
                           FontSize="11" Foreground="{DynamicResource ThemeText2}" VerticalAlignment="Center"/>
                <Border Grid.Row="2" Grid.Column="0" Classes="wizard-kbd">
                  <TextBlock Text="Esc" FontSize="11" FontFamily="Consolas,Courier New,monospace"
                             Foreground="{DynamicResource ThemeText}"/>
                </Border>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="Close panels / exit focus"
                           FontSize="11" Foreground="{DynamicResource ThemeText2}" VerticalAlignment="Center"/>
                <Border Grid.Row="3" Grid.Column="0" Classes="wizard-kbd">
                  <TextBlock Text="Scroll" FontSize="11" FontFamily="Consolas,Courier New,monospace"
                             Foreground="{DynamicResource ThemeText}"/>
                </Border>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="Navigate game grid"
                           FontSize="11" Foreground="{DynamicResource ThemeText2}" VerticalAlignment="Center"/>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Step 5: PlayStation Remote Play -->
        <StackPanel IsVisible="{Binding Step, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=5}"
                    VerticalAlignment="Top" Spacing="12">
          <Border Classes="wizard-card-hi" Padding="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0">
                <TextBlock Text="chiaki-ng" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeText}"/>
                <TextBlock Name="ChiakiStatus" FontSize="11" Foreground="{DynamicResource ThemeText2}"
                           Text="Checking…"/>
              </StackPanel>
              <Button Grid.Column="1" Name="ChiakiDownloadBtn" Classes="action"
                      Content="Download" Click="ChiakiDownload_Click"
                      Padding="14,6"/>
            </Grid>
          </Border>

          <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <TextBlock Grid.Column="0" Text="Registered consoles" FontSize="12"
                       Foreground="{DynamicResource ThemeText3}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Classes="ghost" Content="Open configurator"
                    Click="OpenChiaki_Click" Padding="12,6"/>
          </Grid>

          <Border Classes="wizard-card-hi" Padding="12">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="DISCOVER CONSOLES" Classes="wizard-caps"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Classes="ghost" Content="Discover"
                        Click="DiscoverConsoles_Click" Padding="10,5"/>
              </Grid>
              <ComboBox x:Name="ConsoleHostBox"/>
              <TextBox x:Name="ManualHostBox" Watermark="Manual host IP (fallback)"/>
              <TextBox x:Name="PsnAccountIdBox" Watermark="PSN Account ID (optional)"/>
              <TextBox x:Name="PsnPinBox" Watermark="PIN from console (optional)"/>
              <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                <Button Grid.Column="0" Classes="action" Content="Register"
                        Click="RegisterConsole_Click" Padding="12,6"/>
                <Button Grid.Column="1" Classes="ghost" Content="Wake"
                        Click="WakeConsole_Click" Padding="12,6"/>
              </Grid>
              <TextBlock x:Name="ChiakiWizardStatus" FontSize="11" Foreground="{DynamicResource ThemeText2}"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <StackPanel Orientation="Horizontal" Spacing="6">
            <PathIcon Width="12" Height="12" Foreground="{DynamicResource ThemeText3}"
                      Data="M9,18 H15 M10,22 H14 M12,2 A7,7 0 0 1 16.95,13.95 C16.35,14.56 15.53,15.69 15,17 H9 C8.47,15.69 7.65,14.56 7.05,13.95 A7,7 0 0 1 12,2 Z"/>
            <TextBlock Text="Your PC and PlayStation must be on the same local network. Find the pairing PIN on your console under Settings → System → Remote Play → Link Device."
                       FontSize="11" Foreground="{DynamicResource ThemeText3}" TextWrapping="Wrap"/>
          </StackPanel>
        </StackPanel>

        <!-- Step 6: Done -->
        <StackPanel IsVisible="{Binding Step, Converter={x:Static vm:WizardStepConverter.IsStep}, ConverterParameter=6}"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14" MaxWidth="520">
          <PathIcon Width="44" Height="44" Foreground="#22c55e"
                    HorizontalAlignment="Center"
                    Data="M20,6 A14,14 0 1 0 20,34 A14,14 0 1 0 20,6 M13,20 L18,25 L28,15"/>
          <TextBlock Text="Review the summary below, then launch when you are ready."
                     FontSize="13" Foreground="{DynamicResource ThemeText2}"
                     TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
          <Border Classes="wizard-card-hi" Padding="12">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="🎨" FontSize="13" VerticalAlignment="Top" Margin="0,1,0,0"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="Appearance" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="{Binding AppearanceSummary}" FontSize="11" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
              <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="⚡" FontSize="13" VerticalAlignment="Top" Margin="0,1,0,0"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="Performance" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="{Binding PerformanceSummary}" FontSize="11" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
              <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="✓" FontSize="13" VerticalAlignment="Top" Margin="0,1,0,0" Foreground="#22c55e"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="Accounts" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="{Binding AccountsSummary}" FontSize="11" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
              <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="⚙" FontSize="13" VerticalAlignment="Top" Margin="0,1,0,0"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="Behavior" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="{Binding BehaviorSummary}" FontSize="11" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
              <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="🎮" FontSize="13" VerticalAlignment="Top" Margin="0,1,0,0"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="PlayStation" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="{Binding PlayStationSummary}" FontSize="11" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
              <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="🖼" FontSize="13" VerticalAlignment="Top" Margin="0,1,0,0"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="Artwork" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
                  <TextBlock Text="{Binding ArtworkSummary}" FontSize="11" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>
          <TextBlock Text="Tip: Press Ctrl+K to search your library after launch"
                     FontSize="11" Foreground="{DynamicResource ThemeText3}"
                     HorizontalAlignment="Center" TextAlignment="Center"/>
          <Border Classes="wizard-card-hi" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="Artwork (optional)" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource ThemeText}"/>
              <TextBlock Text="Add a SteamGridDB API key to automatically download high-quality cover art."
                         FontSize="11" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" x:Name="WizardSgdbKeyBox"
                         Text="{Binding SteamGridDbKey}" Watermark="Paste your API key here…"
                         Background="#10ffffff" BorderBrush="#18ffffff" Foreground="{DynamicResource ThemeText}"
                         CornerRadius="8" Padding="12,10" FontSize="13"/>
                <Button Grid.Column="1" Content="Paste" Margin="8,0,0,0"
                        Classes="ghost" Padding="14,10" FontSize="12"
                        Click="PasteSgdbKey_Click"/>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>

      </Panel>
    </ScrollViewer>

    <!-- Bottom nav -->
    <Grid Grid.Row="2" Classes="wizard-foot" ColumnDefinitions="Auto,*,Auto,Auto,Auto">

      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <Ellipse Width="6" Height="6" Fill="{Binding DotBrush0}"/>
        <Ellipse Width="6" Height="6" Fill="{Binding DotBrush1}"/>
        <Ellipse Width="6" Height="6" Fill="{Binding DotBrush2}"/>
        <Ellipse Width="6" Height="6" Fill="{Binding DotBrush3}"/>
        <Ellipse Width="6" Height="6" Fill="{Binding DotBrush4}"/>
        <Ellipse Width="6" Height="6" Fill="{Binding DotBrush5}"/>
        <Ellipse Width="6" Height="6" Fill="{Binding DotBrush6}"/>
      </StackPanel>

      <Border Grid.Column="1"/>

      <Button Grid.Column="2" Classes="ghost" Content="Back"
              Margin="0,0,10,0"
              IsVisible="{Binding CanGoBack}"
              Command="{Binding BackCommand}"/>

      <Button Grid.Column="3" Classes="ghost" Content="Skip"
              Margin="0,0,10,0"
              IsVisible="{Binding CanSkip}"
              Command="{Binding SkipCommand}"/>

      <Button Grid.Column="4" Classes="action"
              Content="{Binding NextLabel}"
              Command="{Binding NextCommand}"
              IsDefault="True"/>
    </Grid>

  </Grid>
</Window>
