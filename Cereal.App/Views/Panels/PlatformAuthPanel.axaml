<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cereal.App.ViewModels"
             x:Class="Cereal.App.Views.Panels.PlatformAuthPanel"
             x:DataType="vm:MainViewModel"
             Background="{DynamicResource ThemeVoid}">

  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0"
            Background="{DynamicResource ThemeCard}"
            BorderBrush="#0fffffff"
            BorderThickness="0,0,0,1"
            Padding="14,8">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
          <TextBlock Text="{Binding PlatformAuthTabTitle}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource ThemeText}"/>
          <TextBlock Text="Complete sign-in in the panel below. Stays in-app with the tab bar like Cloud Gaming."
                     FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource ThemeText3}"/>
        </StackPanel>
        <Button Grid.Column="1" Classes="ghost" Content="Open in browser" Margin="0,0,8,0"
                Padding="12,6" Click="OpenBrowser_Click"/>
        <Button Grid.Column="2" Width="36" Height="32" Classes="ghost" Padding="0"
                Command="{Binding ClosePlatformAuthCommand}" ToolTip.Tip="Close">
          <PathIcon Width="10" Height="10"
                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    Data="M1,1 L9,9 M9,1 L1,9"/>
        </Button>
      </Grid>
    </Border>

    <Border Grid.Row="1" x:Name="WebHost"
            Background="#080818"
            ClipToBounds="True"/>
  </Grid>
</UserControl>
