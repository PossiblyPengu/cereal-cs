<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cereal.App.ViewModels"
             xmlns:conv="using:Cereal.App"
             x:Class="Cereal.App.Views.Panels.FocusPanel"
             x:DataType="vm:MainViewModel"
             KeyboardNavigation.TabNavigation="Cycle"
             Background="Transparent">

  <UserControl.Styles>

    <!-- .btn-play (index.css 529) -->
    <Style Selector="Button.focus-action">
      <Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeVoid}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="24,10"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.focus-action:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#e8b85e"/>
    </Style>
    <Style Selector="Button.focus-action:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#d29f45"/>
    </Style>
    <Style Selector="Button.focus-action:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.focus-action:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="0 0 0 1 #4dd4a853"/>
    </Style>

    <!-- .btn-ghost (index.css 532) — transparent w/ 1px border -->
    <Style Selector="Button.focus-ghost">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="Normal"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="20,10"/>
      <Setter Property="BorderBrush" Value="#17ffffff"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.focus-ghost:pointerover /template/ ContentPresenter">
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeText3}"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>
    <Style Selector="Button.focus-ghost:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#14ffffff"/>
    </Style>
    <Style Selector="Button.focus-ghost:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.focus-ghost:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="0 0 0 1 #4dd4a853"/>
    </Style>

    <Style Selector="Button.focus-danger">
      <Setter Property="Background" Value="#33ff4444"/>
      <Setter Property="Foreground" Value="#ff7070"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.focus-danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#55ff4444"/>
      <Setter Property="TextElement.Foreground" Value="#ff9090"/>
    </Style>
    <Style Selector="Button.focus-danger:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#66ff4444"/>
    </Style>
    <Style Selector="Button.focus-danger:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.focus-danger:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="0 0 0 1 #4dd4a853"/>
    </Style>

    <Style Selector="Button.focus-close">
      <Setter Property="Background" Value="#0dffffff"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.focus-close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#33ffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>
    <Style Selector="Button.focus-close:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#40ffffff"/>
    </Style>
    <Style Selector="Button.focus-close:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="0 0 0 1 #4dd4a853"/>
    </Style>

    <Style Selector="Border.cat-chip">
      <Setter Property="Background" Value="#1ad4a853"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="8,3"/>
    </Style>

  </UserControl.Styles>

  <!-- Root grid — matches Electron .focus-overlay (App.tsx / FocusView.tsx / index.css 412-447).
       Full-screen blurred backdrop, no card chrome — the art + details float on the dim overlay.
       Click anywhere outside the content closes. -->
  <Grid PointerPressed="Root_PointerPressed"
        KeyDown="Root_KeyDown">

    <!-- Blurred background: header image (index.css 413 — scaled 1.2× so blur edges don't show) -->
    <Image Source="{Binding SelectedGame.HeaderPath}"
           Stretch="UniformToFill"
           Opacity="0.12"
           IsHitTestVisible="False">
      <Image.Effect>
        <BlurEffect Radius="70"/>
      </Image.Effect>
      <Image.RenderTransform>
        <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
      </Image.RenderTransform>
    </Image>
    <Image Source="{Binding SelectedGame.CoverPath}"
           IsVisible="{Binding SelectedGame.HasCover}"
           Stretch="UniformToFill"
           Opacity="0.08"
           IsHitTestVisible="False">
      <Image.Effect>
        <BlurEffect Radius="70"/>
      </Image.Effect>
    </Image>

    <!-- Dim overlay (index.css 414 — rgba(7,7,13,0.78)) -->
    <Border Background="#c707070d" IsHitTestVisible="False"/>

    <!-- Content row (index.css 415): art + details, 48px gap, max 860px, 80vh -->
    <Border x:Name="ContentCard"
            PointerPressed="ContentCard_PointerPressed"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="32,48,32,48"
            MaxWidth="860"
            Background="Transparent">

      <Grid ColumnDefinitions="Auto,48,*" MaxHeight="620">

        <!-- Left: cover art — 340px tall, 14px corners, deep shadow (index.css 420) -->
        <Panel Grid.Column="0" Width="220" Height="340"
               VerticalAlignment="Top">
          <Border CornerRadius="14" ClipToBounds="True"
                  BoxShadow="0 24 64 0 #990a0a14">
            <Panel>
              <Border Background="{DynamicResource ThemeCardUp}"/>
              <TextBlock Text="{Binding SelectedGame.Initial}"
                         FontSize="80" FontWeight="Light"
                         Foreground="#1de8e4de"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsVisible="{Binding !SelectedGame.HasCover}"/>
              <Image Source="{Binding SelectedGame.CoverPath}"
                     IsVisible="{Binding SelectedGame.HasCover}"
                     Stretch="UniformToFill"/>
            </Panel>
          </Border>
        </Panel>

        <!-- Right: game details + actions -->
        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Top"
                      MaxHeight="620">
          <StackPanel Margin="0,0,0,0" Spacing="0">

            <!-- Platform pill + Refresh Info row (index.css 423-446) -->
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,14">
              <Border Grid.Column="0"
                      CornerRadius="6" Padding="12,4"
                      HorizontalAlignment="Left"
                      Background="Transparent"
                      BorderThickness="1"
                      BorderBrush="{Binding SelectedGame.PlatformColor}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Ellipse Width="6" Height="6"
                           Fill="{Binding SelectedGame.PlatformColor}"
                           VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding SelectedGame.PlatformLabel}"
                             FontSize="10" FontWeight="Bold"
                             LetterSpacing="0.5"
                             Foreground="{Binding SelectedGame.PlatformColor}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Button Grid.Column="2" Content="{Binding RefreshInfoButtonLabel}"
                      Background="Transparent"
                      Foreground="{DynamicResource ThemeText4}"
                      FontSize="10"
                      BorderBrush="#17ffffff" BorderThickness="1"
                      CornerRadius="6" Padding="10,3"
                      Cursor="Hand"
                      Command="{Binding RefreshGameInfoCommand}"
                      IsEnabled="{Binding !IsRefreshingGameInfo}"
                      IsVisible="{Binding SelectedGame, Converter={x:Static conv:ObjectConverters.IsNotNull}}"/>
            </Grid>

            <!-- Game title — 32px heavy, line-height 1.1 (index.css 425) -->
            <TextBlock Text="{Binding SelectedGame.Name}"
                       FontSize="32" FontWeight="Bold"
                       LineHeight="36"
                       Foreground="{DynamicResource ThemeText}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,10"/>

            <!-- Metacritic badge -->
            <Border IsVisible="{Binding SelectedGame.HasMetacritic}"
                    CornerRadius="4" Padding="8,3"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,8"
                    Background="{Binding SelectedGame.MetacriticBgBrush}">
              <TextBlock Foreground="{Binding SelectedGame.MetacriticFgBrush}"
                         FontSize="11" FontWeight="Bold">
                <Run Text="{Binding SelectedGame.Metacritic}"/>
                <Run Text=" Metacritic"/>
              </TextBlock>
            </Border>

            <!-- Playtime / Last played row -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
              <TextBlock Text="{Binding SelectedGame.PlaytimeLabel}"
                         FontSize="12" Foreground="{DynamicResource ThemeText2}"/>
              <TextBlock Text="|" FontSize="12" Foreground="{DynamicResource ThemeText4}"
                         IsVisible="{Binding SelectedGame.PlaytimeLabel, Converter={x:Static conv:ObjectConverters.IsNotNull}}"/>
              <TextBlock Text="{Binding SelectedGame.LastPlayedLabel}"
                         FontSize="12" Foreground="{DynamicResource ThemeText3}"/>
            </StackPanel>

            <!-- Developer / Publisher / Release date — two-col info grid (index.css .focus-info-grid) -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" Margin="0,0,0,16"
                  IsVisible="{Binding SelectedGame.HasAnyInfoItem}">
              <StackPanel Grid.Column="0" Grid.Row="0" Spacing="2" Margin="0,0,16,6"
                          IsVisible="{Binding SelectedGame.HasDeveloper}">
                <TextBlock Text="Developer" FontSize="9" FontWeight="SemiBold"
                           LetterSpacing="0.8"
                           Foreground="#40b0aaa0"/>
                <TextBlock Text="{Binding SelectedGame.Developer}"
                           FontSize="12" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Grid.Row="0" Spacing="2" Margin="0,0,0,6"
                          IsVisible="{Binding SelectedGame.HasPublisher}">
                <TextBlock Text="Publisher" FontSize="9" FontWeight="SemiBold"
                           LetterSpacing="0.8"
                           Foreground="#40b0aaa0"/>
                <TextBlock Text="{Binding SelectedGame.Publisher}"
                           FontSize="12" Foreground="{DynamicResource ThemeText2}" TextWrapping="Wrap"/>
              </StackPanel>
              <StackPanel Grid.Column="0" Grid.Row="1" Spacing="2" Margin="0,0,16,0"
                          IsVisible="{Binding SelectedGame.HasReleaseDate}">
                <TextBlock Text="Released" FontSize="9" FontWeight="SemiBold"
                           LetterSpacing="0.8"
                           Foreground="#40b0aaa0"/>
                <TextBlock Text="{Binding SelectedGame.ReleaseDate}"
                           FontSize="12" Foreground="{DynamicResource ThemeText2}"/>
              </StackPanel>
            </Grid>

            <!-- Categories -->
            <ItemsControl IsVisible="{Binding SelectedGame.HasCategories}"
                          ItemsSource="{Binding SelectedGame.Game.Categories}"
                          Margin="0,0,0,10">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="cat-chip" Margin="0,0,4,4">
                    <TextBlock Text="{Binding}" FontSize="10" Foreground="{DynamicResource ThemeAccent}"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Optional website link -->
            <Button Content="{Binding SelectedGame.Website}"
                    Command="{Binding OpenSelectedGameWebsiteCommand}"
                    IsVisible="{Binding SelectedGame.HasWebsite}"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Foreground="{DynamicResource ThemeAccent}"
                    BorderThickness="0"
                    Padding="0,0,0,0"
                    FontSize="11"
                    Margin="0,0,0,10"
                    Cursor="Hand"/>

            <!-- Description — max-height 100, overflow scroll (index.css .focus-desc) -->
            <ScrollViewer IsVisible="{Binding SelectedGame.HasDescription}"
                          MaxHeight="100"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,12">
              <TextBlock Text="{Binding SelectedGame.Description}"
                         FontSize="12" LineHeight="19"
                         Foreground="{DynamicResource ThemeText3}"
                         TextWrapping="Wrap"/>
            </ScrollViewer>

            <!-- Notes -->
            <StackPanel IsVisible="{Binding SelectedGame.HasNotes}" Margin="0,0,0,10">
              <TextBlock Text="NOTES" FontSize="9" FontWeight="SemiBold"
                         LetterSpacing="0.8" Foreground="#40b0aaa0" Margin="0,0,0,4"/>
              <TextBlock Text="{Binding SelectedGame.Notes}"
                         FontSize="12" Foreground="{DynamicResource ThemeText3}"
                         TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Screenshot strip -->
            <ScrollViewer IsVisible="{Binding SelectedGame.HasScreenshots}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="0,0,0,10">
              <ItemsControl ItemsSource="{Binding SelectedGame.Game.Screenshots}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="6"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border CornerRadius="4" ClipToBounds="True" Width="120" Height="80"
                            Cursor="Hand"
                            PointerPressed="Screenshot_PointerPressed">
                      <Image Source="{Binding}" Stretch="UniformToFill"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <Button Classes="focus-action"
                      Command="{Binding LaunchGameCommand}"
                      CommandParameter="{Binding SelectedGame}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <PathIcon Width="14" Height="14"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Data="M8,5.14 V18.86 A1,1 0 0 0 9.5,19.72 L20.54,12.86 A1,1 0 0 0 20.54,11.14 L9.5,4.28 A1,1 0 0 0 8,5.14 Z"/>
                  <TextBlock Text="Play" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Classes="focus-ghost"
                      Command="{Binding SelectedGame.ToggleFavoriteCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <PathIcon Width="14" Height="14"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Data="M12,2 L15.09,8.26 L22,9.27 L17,14.14 L18.18,21.02 L12,17.77 L5.82,21.02 L7,14.14 L2,9.27 L8.91,8.26 Z"/>
                  <TextBlock Text="{Binding SelectedGame.FavoriteLabel}" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Classes="focus-ghost" Command="{Binding EditGameCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <PathIcon Width="14" Height="14"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Data="M11,4 H4 A2,2 0 0 0 2,6 V20 A2,2 0 0 0 4,22 H18 A2,2 0 0 0 20,20 V13 M18.5,2.5 A2.121,2.121 0 0 1 21.5,5.5 L12,15 L8,16 L9,12 Z"/>
                  <TextBlock Text="Edit" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Classes="focus-danger"
                      Command="{Binding DeleteGameCommand}"
                      CommandParameter="{Binding SelectedGame.Id}"
                      Click="Delete_Click">
                <PathIcon Width="14" Height="14"
                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="M3,6 H5 H21 M19,6 L18,20 A2,2 0 0 1 16,22 H8 A2,2 0 0 1 6,20 L5,6 M10,11 V17 M14,11 V17 M9,6 V4 A1,1 0 0 1 10,3 H14 A1,1 0 0 1 15,4 V6"/>
              </Button>
            </StackPanel>

            <!-- Secondary actions (mirrors electron games:install / games:openInClient) -->
            <Border Height="1" Background="#0bffffff" Margin="0,8,0,4"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="focus-ghost" Content="Install"
                      Command="{Binding InstallGameCommand}"
                      IsVisible="{Binding SelectedGame.IsNotInstalled}"/>
              <Button Classes="focus-ghost" Content="Open in client"
                      Command="{Binding OpenInClientCommand}"/>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>

      </Grid>
    </Border>

    <!-- Close button top-right -->
    <Button Classes="focus-close"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,44,32,0"
            Command="{Binding CloseFocusCommand}">
      <PathIcon Width="14" Height="14"
                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                Data="M3,3 L11,11 M11,3 L3,11"/>
    </Button>

    <!-- ESC hint bottom center -->
    <TextBlock Text="ESC to close"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Margin="0,0,0,32"
               FontSize="10"
               Foreground="#40b0aaa0"
               IsHitTestVisible="False"/>

    <!-- Screenshot zoom overlay -->
    <Panel IsVisible="{Binding ZoomScreenshotUrl,
                       Converter={x:Static conv:ObjectConverters.IsNotNull}}"
           PointerPressed="Zoom_PointerPressed">
      <Border Background="#ee07070d"/>
      <Border HorizontalAlignment="Center" VerticalAlignment="Center"
              MaxWidth="1000" MaxHeight="620" Margin="40"
              CornerRadius="8" ClipToBounds="True"
              PointerPressed="ZoomImage_PointerPressed">
        <Image Source="{Binding ZoomScreenshotUrl}" Stretch="Uniform"/>
      </Border>
      <TextBlock Text="click to close"
                 HorizontalAlignment="Center" VerticalAlignment="Bottom"
                 Margin="0,0,0,20" FontSize="11" Foreground="#28b0aaa0"
                 IsHitTestVisible="False"/>
    </Panel>

  </Grid>
</UserControl>
