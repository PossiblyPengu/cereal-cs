<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cereal.App.ViewModels"
             xmlns:conv="using:Cereal.App"
             x:Class="Cereal.App.Views.Panels.DetectPanel"
             x:DataType="vm:DetectViewModel"
             Background="Transparent">

  <UserControl.Styles>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="32,24">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock Text="PLATFORMS" FontSize="9" FontWeight="Bold"
                 LetterSpacing="1.5" Foreground="#40b0aaa0" Margin="0,0,0,6"/>
      <TextBlock Text="Detect Games" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
      <TextBlock Text="Scan your installed platforms and import games into your library."
                 FontSize="13" Foreground="#50b0aaa0" Margin="0,4,0,0" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- Main content: provider toggles + results -->
    <Grid Grid.Row="1" ColumnDefinitions="200,*">

      <!-- Provider list -->
      <StackPanel Grid.Column="0" Spacing="4">
        <TextBlock Text="PLATFORMS" Foreground="#40b0aaa0" FontSize="9" FontWeight="Bold"
                   LetterSpacing="1.5" Margin="0,0,0,8"/>
        <ItemsControl ItemsSource="{Binding Providers}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ProviderToggle">
              <CheckBox Content="{Binding PlatformId}"
                        IsChecked="{Binding Enabled}"
                        Margin="0,2"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="Scan installed games"
                Command="{Binding ScanCommand}"
                IsEnabled="{Binding !IsScanning}"
                Background="#d4a853" Foreground="#07070d"
                CornerRadius="6" Padding="14,8" BorderThickness="0"
                HorizontalAlignment="Left" Margin="0,16,0,0" Cursor="Hand"/>
      </StackPanel>

      <!-- Results -->
      <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="24,0,0,0">

        <!-- Column header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,100,60" Margin="0,0,0,4">
          <TextBlock Grid.Column="0" Text="Game" Foreground="#40b0aaa0" FontSize="11" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="1" Text="Platform" Foreground="#40b0aaa0" FontSize="11" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="2" Text="Add" Foreground="#40b0aaa0" FontSize="11" FontWeight="SemiBold"/>
        </Grid>
        <Border Grid.Row="0" Height="1" Background="#0fffffff" VerticalAlignment="Bottom"/>

        <ScrollViewer Grid.Row="1">
          <ItemsControl ItemsSource="{Binding Results}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:DetectedGameRow">
                <Grid ColumnDefinitions="*,100,60" Margin="0,5">
                  <TextBlock Grid.Column="0" Text="{Binding Name}"
                             Foreground="{Binding IsImported, Converter={x:Static conv:BoolConverters.ToObject},
                               ConverterParameter='#40b0aaa0,#e8e4de'}"
                             FontSize="12"
                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Column="1" Text="{Binding Platform}"
                             Foreground="#50b0aaa0" VerticalAlignment="Center" FontSize="11"/>
                  <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected}"
                            IsEnabled="{Binding !IsImported}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>

    </Grid>

    <!-- Footer -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
      <TextBlock VerticalAlignment="Center" Foreground="#50b0aaa0" FontSize="12">
        <TextBlock.Text>
          <MultiBinding StringFormat="{}{0} found  ·  {1} added">
            <Binding Path="FoundCount"/>
            <Binding Path="AddedCount"/>
          </MultiBinding>
        </TextBlock.Text>
      </TextBlock>
      <Button Content="Import selected"
              Command="{Binding ImportSelectedCommand}"
              Background="#d4a853" Foreground="#07070d"
              CornerRadius="6" Padding="14,8" BorderThickness="0" Cursor="Hand"/>
      <Button Content="Import all"
              Command="{Binding ImportAllCommand}"
              Background="#14ffffff" Foreground="{DynamicResource ThemeText2}"
              CornerRadius="6" Padding="14,8" BorderThickness="1"
              BorderBrush="#10ffffff" Cursor="Hand"/>
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
             Foreground="#50b0aaa0" FontSize="12"
             IsVisible="{Binding StatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}"/>
    </StackPanel>

  </Grid>
</UserControl>
