<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:Cereal.App.Services.Integrations"
             xmlns:local="using:Cereal.App.Views.Panels"
             x:Class="Cereal.App.Views.Panels.XcloudPanel"
             x:DataType="local:XcloudPanel"
             Background="Transparent">

  <Grid RowDefinitions="Auto,Auto,*" Margin="12">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBox x:Name="UrlBox" Width="420" Watermark="https://www.xbox.com/play"/>
      <Button Content="Open Xbox Cloud" Click="Start_Click"/>
    </StackPanel>

    <Border Grid.Row="1" x:Name="WebViewHost" Height="420" Background="#001122" CornerRadius="6" Margin="0,12,0,0">
      <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#66ccccff" Text="Xbox Cloud WebView host"/>
    </Border>

    <ListBox Grid.Row="2" ItemsSource="{Binding Sessions}" Margin="0,12,0,0">
      <ListBox.ItemTemplate>
        <DataTemplate DataType="services:XcloudSessionInfo">
          <Border Padding="8" Margin="0,4" Background="#111122" CornerRadius="6">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel>
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding GameId}" Foreground="#88ccccff"/>
                <TextBlock Text="{Binding State}" Foreground="#66ccccff"/>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
