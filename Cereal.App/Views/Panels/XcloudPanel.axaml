<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:Cereal.App.Services.Integrations"
             xmlns:local="using:Cereal.App.Views.Panels"
             x:Class="Cereal.App.Views.Panels.XcloudPanel"
             x:DataType="local:XcloudPanel"
             Background="{DynamicResource ThemeVoid}">

  <UserControl.Styles>
    <Style Selector="Button.xc-btn">
      <Setter Property="Background" Value="#14ffffff"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="MinHeight" Value="30"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#0fffffff"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="Button.xc-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#22ffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
      <Setter Property="BorderBrush" Value="#18ffffff"/>
    </Style>
    <Style Selector="Button.xc-btn:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.xc-btn:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="0 0 0 1 #4dd4a853"/>
    </Style>
    <Style Selector="Button.xc-primary">
      <Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeVoid}"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="MinHeight" Value="30"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.xc-primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#e8b85e"/>
    </Style>
    <Style Selector="Button.xc-primary:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.xc-primary:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="0 0 0 1 #4dd4a853"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ── Top bar ── -->
    <Border Grid.Row="0"
            Background="{DynamicResource ThemeCard}"
            BorderBrush="#0fffffff"
            BorderThickness="0,0,0,1"
            Padding="14,8">
      <StackPanel Spacing="8">
        <!-- URL box -->
        <Border CornerRadius="7" Background="#0cffffff"
                BorderBrush="#0fffffff" BorderThickness="1"
                Padding="10,0">
          <Grid ColumnDefinitions="Auto,*">
            <PathIcon Grid.Column="0" Width="13" Height="13"
                      Foreground="#40b0aaa0" VerticalAlignment="Center"
                      Margin="0,0,6,0"
                      Data="M7,18 H18 A4,4 0 0 0 18,10 A6,6 0 0 0 6.4,8.2 A4,4 0 0 0 7,18 Z"/>
            <TextBox Grid.Column="1" x:Name="UrlBox"
                     Watermark="https://www.xbox.com/play"
                     BorderThickness="0" Background="Transparent"
                     Foreground="{DynamicResource ThemeText}" CaretBrush="{DynamicResource ThemeAccent}"
                     FontSize="12" Padding="0,6" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <WrapPanel Orientation="Horizontal">
          <!-- Launch -->
          <Button Classes="xc-primary" Content="Open Xbox Cloud"
                  Margin="0,0,6,0" Click="Start_Click"/>
          <!-- Stop current session -->
          <Button Classes="xc-btn" Content="Stop"
                  Margin="0,0,6,0" Click="Stop_Click"/>
          <!-- Open externally in browser -->
          <Button Classes="xc-btn" Content="Browser"
                  Margin="0,0,6,0" Click="Browser_Click"/>
          <!-- Close panel -->
          <Button Classes="xc-btn"
                  Width="34" Padding="0" Click="Close_Click">
            <PathIcon Width="10" Height="10"
                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M1,1 L9,9 M9,1 L1,9"/>
          </Button>
        </WrapPanel>
      </StackPanel>
    </Border>

    <!-- ── WebView host ── -->
    <Border Grid.Row="1" x:Name="WebViewHost"
            Background="{DynamicResource ThemeBodyBg}"
            ClipToBounds="True">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <PathIcon Width="56" Height="56" Foreground="#1affffff"
                  HorizontalAlignment="Center"
                  Data="M7,18 H18 A4,4 0 0 0 18,10 A6,6 0 0 0 6.4,8.2 A4,4 0 0 0 7,18 Z"/>
        <TextBlock Text="Xbox Cloud Gaming" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeText2}" HorizontalAlignment="Center"/>
        <TextBlock Text="Enter a URL and click &quot;Open Xbox Cloud&quot; to start."
                   FontSize="12" Foreground="{DynamicResource ThemeText3}"
                   HorizontalAlignment="Center" TextAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- ── Active sessions footer ── -->
    <Border Grid.Row="2"
            Background="{DynamicResource ThemeCard}"
            BorderBrush="#0fffffff"
            BorderThickness="0,1,0,0"
            Padding="14,8">
      <ItemsControl ItemsSource="{Binding Sessions}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" Spacing="8"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="services:XcloudSessionInfo">
            <Button Padding="10,6" CornerRadius="6" MinHeight="30"
                    Background="#14ffffff" BorderBrush="#0fffffff" BorderThickness="1"
                    Cursor="Hand" Click="Session_Click">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                         Fill="#22c55e"/>
                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding State}" FontSize="11"
                           Foreground="{DynamicResource ThemeText3}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

  </Grid>
</UserControl>
