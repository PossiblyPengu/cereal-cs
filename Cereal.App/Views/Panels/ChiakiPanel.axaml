<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Cereal.App"
             xmlns:local="using:Cereal.App.Views.Panels"
             x:Class="Cereal.App.Views.Panels.ChiakiPanel"
             x:DataType="local:ChiakiPanelViewModel"
             Background="Transparent">

  <UserControl.Styles>
  </UserControl.Styles>

  <Border Background="{DynamicResource ThemeSurface}"
          BorderBrush="#14ffffff"
          BorderThickness="1,0,0,0">
  <Grid RowDefinitions="Auto,*">

    <!-- Header -->
    <Border Grid.Row="0" Padding="16,12,16,12"
            BorderBrush="#0affffff" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="PlayStation Remote Play" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource ThemeText}"/>
          <Border CornerRadius="4" Padding="6,2" Background="{Binding StatusBg}"
                  HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <Ellipse Width="5" Height="5" Fill="{Binding StatusDot}" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="SemiBold"
                         Foreground="{Binding StatusFg}"/>
              <TextBlock Text="{Binding StatusVersion}" FontSize="10" Foreground="{Binding StatusFg}"
                         Opacity="0.7"
                         IsVisible="{Binding StatusVersion, Converter={x:Static conv:ObjectConverters.IsNotNull}}"/>
            </StackPanel>
          </Border>
        </StackPanel>
        <Button Grid.Column="1" Classes="sm" Content="Open chiaki-ng"
                Click="OpenGui_Click" VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="16,14,16,16" Spacing="14">

        <!-- ── Consoles ── -->
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="MY CONSOLES" FontSize="9" FontWeight="Bold"
                     LetterSpacing="1.5" Foreground="#40b0aaa0" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Classes="sm" Content="+ Add"
                  Click="ShowAddConsole_Click"/>
        </Grid>

        <!-- Add form -->
        <Border IsVisible="{Binding ShowAddConsoleForm}"
                Background="#0fffffff" BorderBrush="#14ffffff" BorderThickness="1"
                CornerRadius="10" Padding="12">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,12,*">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Nickname" FontSize="10" Foreground="#50b0aaa0"/>
                <TextBox Classes="field" x:Name="NewNicknameBox" Watermark="PS5-Living-Room"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="Host IP" FontSize="10" Foreground="#50b0aaa0"/>
                <TextBox Classes="field" x:Name="NewHostBox" Watermark="192.168.1.x"/>
              </StackPanel>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <Button Classes="sm" Content="Cancel" Click="CancelAddConsole_Click"/>
              <Button Classes="action" Content="Add" Click="AddConsole_Click"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Empty state -->
        <Border IsVisible="{Binding HasNoConsoles}"
                Background="#0affffff" CornerRadius="10" Padding="14">
          <StackPanel Spacing="6" HorizontalAlignment="Center">
            <TextBlock Text="No consoles yet" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeText2}" TextAlignment="Center"/>
            <TextBlock Text="Scan the network or add one manually."
                       FontSize="11" Foreground="#50b0aaa0" TextAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Console cards -->
        <ItemsControl ItemsSource="{Binding Consoles}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="local:ChiakiConsoleViewModel">
              <Border Background="#0fffffff" BorderBrush="#14ffffff" BorderThickness="1"
                      CornerRadius="10" Padding="12,10" Margin="0,0,0,6">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8"
                          Background="#1a3b82f6" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="PS" FontSize="10" FontWeight="Bold" Foreground="#3b82f6"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding Nickname}" FontSize="12" FontWeight="SemiBold"
                                 Foreground="{DynamicResource ThemeText}"/>
                      <Border IsVisible="{Binding IsLive}" Background="#1a22c55e"
                              CornerRadius="4" Padding="5,1" VerticalAlignment="Center">
                        <TextBlock Text="LIVE" FontSize="9" FontWeight="Bold" Foreground="#22c55e"/>
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Host}" FontSize="11" Foreground="#50b0aaa0"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Classes="danger" Content="Stop"
                            IsVisible="{Binding IsLive}"
                            Tag="{Binding Host}" Click="StopConsole_Click"/>
                    <Button Classes="action" Content="Connect"
                            IsVisible="{Binding !IsLive}"
                            Tag="{Binding .}" Click="ConnectConsole_Click"/>
                    <Button Classes="sm" Content="Wake"
                            IsVisible="{Binding !IsLive}"
                            Tag="{Binding .}" Click="WakeConsole_Click"/>
                    <Button Classes="sm" Tag="{Binding .}" Click="RemoveConsole_Click" Padding="8,6" ToolTip.Tip="Remove">
                      <PathIcon Width="9" Height="9"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Data="M1,1 L9,9 M9,1 L1,9"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ── Discover ── -->
        <Border Height="1" Background="#0affffff"/>

        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
            <TextBlock Text="DISCOVER" FontSize="9" FontWeight="Bold"
                       LetterSpacing="1.5" Foreground="#40b0aaa0"/>
            <TextBlock Text="Find consoles on your local network."
                       FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
          </StackPanel>
          <Button Grid.Column="1" Classes="action" Content="Scan" Click="Discover_Click"/>
        </Grid>

        <Border IsVisible="{Binding IsDiscovering}"
                Background="{DynamicResource ThemeAccentSoft}" CornerRadius="6" Padding="10,7">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="5" Height="5" Fill="{DynamicResource ThemeAccent}" VerticalAlignment="Center"/>
            <TextBlock Text="Scanning…" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeAccent}"/>
          </StackPanel>
        </Border>

        <ItemsControl ItemsSource="{Binding DiscoveredConsoles}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="local:DiscoveredConsoleViewModel">
              <Border Background="#0fffffff" BorderBrush="#14ffffff" BorderThickness="1"
                      CornerRadius="10" Padding="12,10" Margin="0,0,0,6">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8"
                          Background="#1a3b82f6" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TypeLabel}" FontSize="9" FontWeight="Bold"
                               Foreground="#3b82f6"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeText}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding Host}" FontSize="11" Foreground="#50b0aaa0"/>
                      <Border IsVisible="{Binding IsReady}" Background="#1a22c55e"
                              CornerRadius="3" Padding="4,1">
                        <TextBlock Text="Awake" FontSize="9" Foreground="#22c55e"/>
                      </Border>
                      <Border IsVisible="{Binding IsStandby}" Background="#14ffffff"
                              CornerRadius="3" Padding="4,1">
                        <TextBlock Text="Standby" FontSize="9" Foreground="{DynamicResource ThemeText3}"/>
                      </Border>
                    </StackPanel>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Classes="action" Content="Add"
                            IsVisible="{Binding !AlreadyAdded}"
                            Tag="{Binding .}" Click="AddDiscovered_Click"/>
                    <Button Classes="sm" Content="Added"
                            IsVisible="{Binding AlreadyAdded}"
                            IsEnabled="False"/>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ── Pair ── -->
        <Border Height="1" Background="#0affffff"/>

        <TextBlock Text="PAIR A CONSOLE" FontSize="9" FontWeight="Bold"
                   LetterSpacing="1.5" Foreground="#40b0aaa0"/>

        <StackPanel Spacing="8">
          <StackPanel Spacing="4">
            <TextBlock Text="Console IP" FontSize="10" Foreground="#50b0aaa0"/>
            <TextBox Classes="field" x:Name="RegHostBox" Watermark="192.168.1.x"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="PSN Account ID (Base64)" FontSize="10" Foreground="#50b0aaa0"/>
            <TextBox Classes="field" x:Name="RegAccountIdBox" Watermark="ab12CDef3ghIjk…"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="Link Code (8 digits)" FontSize="10" Foreground="#50b0aaa0"/>
            <TextBox Classes="field" x:Name="RegPinBox" Watermark="12345678" MaxLength="8"/>
          </StackPanel>
        </StackPanel>

        <Border IsVisible="{Binding RegStatus, Converter={x:Static conv:ObjectConverters.IsNotNull}}"
                CornerRadius="6" Padding="10,8" Background="{Binding RegStatusBg}">
          <TextBlock Text="{Binding RegStatus}" FontSize="11"
                     Foreground="{Binding RegStatusFg}" TextWrapping="Wrap"/>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="action" Content="Pair" Click="Register_Click"/>
          <Button Classes="sm" Content="Reset" Click="RegReset_Click"/>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

  </Grid>
  </Border>
</UserControl>
