<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cereal.App.ViewModels"
             xmlns:conv="using:Cereal.App"
             xmlns:views="using:Cereal.App.Views"
             x:Class="Cereal.App.Views.MainView"
             x:DataType="vm:MainViewModel"
             Background="Transparent">

  <UserControl.Styles>

    <!-- ── Nav pill chip ── -->
    <Style Selector="Button.chip">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText3}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.chip:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#08ffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText2}"/>
    </Style>
    <Style Selector="Button.chip.active">
      <Setter Property="Background" Value="#1fd4a853"/>
      <Setter Property="BorderBrush" Value="#4dd4a853"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
    </Style>

    <!-- ── Nav pill icon button ── -->
    <Style Selector="Button.nav-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText3}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="30"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#08ffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>

    <!-- ── View toggle button ── -->
    <Style Selector="Button.view-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText4}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="26"/>
      <Setter Property="Height" Value="26"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.view-btn:pointerover /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText2}"/>
    </Style>
    <Style Selector="Button.view-btn.active">
      <Setter Property="Background" Value="#1fd4a853"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
    </Style>

    <!-- ── Game card ── -->
    <Style Selector="Border.game-card">
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Background" Value="{DynamicResource ThemeCard}"/>
      <Setter Property="BorderBrush" Value="#0fffffff"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="ClipToBounds" Value="True"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="RenderTransform" Value="scale(1) translateY(0px)"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18"/>
          <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.18"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.game-card:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.02) translateY(-4px)"/>
      <Setter Property="BoxShadow" Value="0 12 32 0 #660a0a14"/>
      <Setter Property="BorderBrush" Value="#1affffff"/>
    </Style>

    <!-- Not-installed: dimmed -->
    <Style Selector="Border.game-card.not-installed">
      <Setter Property="Opacity" Value="0.55"/>
    </Style>
    <Style Selector="Border.game-card.not-installed:pointerover">
      <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <!-- Hover actions: hidden by default, visible on card hover -->
    <Style Selector="Border.game-card Panel Border.hover-actions">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.game-card:pointerover Panel Border.hover-actions">
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- Search box -->
    <Style Selector="TextBox.search">
      <Setter Property="Background" Value="#08ffffff"/>
      <Setter Property="BorderBrush" Value="#0fffffff"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource ThemeAccent}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="MinWidth" Value="160"/>
    </Style>
    <Style Selector="TextBox.search:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="#4dd4a853"/>
    </Style>

    <!-- ── Stream pill button (index.css 707-710) ── -->
    <Style Selector="Button.stream-pill-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText3}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.stream-pill-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#10ffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>

    <!-- Play / ghost hover buttons -->
    <Style Selector="Button.btn-play-hover">
      <Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeVoid}"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.btn-ghost-hover">
      <Setter Property="Background" Value="#14ffffff"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="BorderBrush" Value="#14ffffff"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>

  </UserControl.Styles>

  <!-- Root panel — content + floating nav pill -->
  <Panel>

    <!-- ── Card grid (scroll area) ── -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  IsVisible="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}">
      <StackPanel Margin="32,60,32,40">

        <!-- Empty state — matches Electron App.tsx 1158-1168 (:/ icon, title, text, two action buttons) -->
        <StackPanel IsVisible="{Binding !GameGroups.Count}"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="0,80,0,0" Spacing="14">
          <TextBlock Text=":/" FontSize="48" Foreground="#33e8e4de"
                     FontWeight="Light" LetterSpacing="4"
                     HorizontalAlignment="Center" Margin="0,0,0,2"/>
          <TextBlock Text="No games yet" FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource ThemeText3}" HorizontalAlignment="Center"/>
          <TextBlock Text="Add games manually or detect from installed platforms."
                     FontSize="13" Foreground="{DynamicResource ThemeText4}"
                     HorizontalAlignment="Center" MaxWidth="320"
                     TextWrapping="Wrap" TextAlignment="Center"/>
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center"
                      Margin="0,6,0,0">
            <Button Content="Add Game"
                    Background="{DynamicResource ThemeAccent}" Foreground="{DynamicResource ThemeVoid}"
                    CornerRadius="10" Padding="20,9" FontSize="13" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding ShowAddGameCommand}"/>
            <Button Content="Detect"
                    Background="Transparent" Foreground="{DynamicResource ThemeText2}"
                    BorderBrush="#1affffff" BorderThickness="1"
                    CornerRadius="10" Padding="20,9" FontSize="13"
                    Cursor="Hand"
                    Command="{Binding OpenDetectCommand}"/>
          </StackPanel>
        </StackPanel>

        <!-- Platform groups -->
        <ItemsControl ItemsSource="{Binding GameGroups}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:PlatformGroupViewModel">
              <StackPanel Margin="0,0,0,28">

                <!-- Section header -->
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="2,0,0,14"
                            VerticalAlignment="Center">
                  <Ellipse Width="8" Height="8" Fill="{Binding PlatformColor}"
                           VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding PlatformLabel}"
                             FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText2}"
                             LetterSpacing="0.5" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding CountLabel}"
                             FontSize="11" Foreground="{DynamicResource ThemeText4}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Cards wrap panel -->
                <ItemsControl ItemsSource="{Binding Games}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" ItemWidth="150"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:GameCardViewModel">
                      <Border Classes="game-card" Width="150" Margin="0,0,14,14"
                              Classes.not-installed="{Binding IsNotInstalled}"
                              Tapped="Card_Tapped"
                              DoubleTapped="Card_DoubleTapped">
                        <!-- Card layout: cover (225px 2:3) + info -->
                        <Grid RowDefinitions="225,Auto">

                          <!-- Cover image area -->
                          <Panel Grid.Row="0">
                            <!-- Fallback background -->
                            <Border Background="{DynamicResource ThemeCardUp}">
                              <TextBlock Text="{Binding Initial}"
                                         FontSize="48" FontWeight="Light"
                                         Foreground="#1de8e4de"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>

                            <!-- Cover image (if loaded) -->
                            <Image Source="{Binding CoverPath}"
                                   Stretch="UniformToFill"
                                   IsVisible="{Binding HasCover}"/>

                            <!-- Bottom gradient overlay -->
                            <Border VerticalAlignment="Bottom" Height="80"
                                    IsHitTestVisible="False">
                              <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                  <GradientStop Color="Transparent" Offset="0"/>
                                  <GradientStop Color="#b207070d" Offset="1"/>
                                </LinearGradientBrush>
                              </Border.Background>
                            </Border>

                            <!-- Platform badge top-left (index.css 800): 2px 8px padding, 9px bold letter -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Margin="8" CornerRadius="4" Padding="8,2"
                                    Background="#8c000000">
                              <TextBlock Text="{Binding PlatformLetter}"
                                         FontSize="9" FontWeight="Bold"
                                         Foreground="{Binding PlatformColor}"/>
                            </Border>

                            <!-- Favorite star top-right (index.css 798) — gold circle with star -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="8" Width="22" Height="22"
                                    CornerRadius="11"
                                    Background="#e6d4a853"
                                    BoxShadow="0 2 8 0 #4cd4a853"
                                    IsVisible="{Binding IsFavorite}">
                              <TextBlock Text="★" FontSize="10" Foreground="{DynamicResource ThemeVoid}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>

                            <!-- Not-installed badge bottom-right (index.css 765) -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Margin="8" Width="22" Height="22"
                                    CornerRadius="11"
                                    Background="#bf000000"
                                    BorderBrush="#26ffffff" BorderThickness="1"
                                    IsVisible="{Binding IsNotInstalled}">
                              <TextBlock Text="↓" FontSize="10" Foreground="#99ffffff"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>

                            <!-- Hover action buttons (bottom) -->
                            <Border Classes="hover-actions"
                                    VerticalAlignment="Bottom"
                                    IsHitTestVisible="False">
                              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                          Spacing="6" Margin="8,8">
                                <Button Classes="btn-play-hover" Content="Play"
                                        IsHitTestVisible="True"
                                        Click="PlayBtn_Click"/>
                                <Button Classes="btn-ghost-hover"
                                        Content="{Binding FavoriteLabel}"
                                        IsHitTestVisible="True"
                                        Click="FavBtn_Click"/>
                              </StackPanel>
                            </Border>
                          </Panel>

                          <!-- Card info -->
                          <Border Grid.Row="1" Padding="10,8,10,10">
                            <StackPanel Spacing="2">
                              <TextBlock Text="{Binding Name}"
                                         FontSize="12" FontWeight="SemiBold"
                                         Foreground="{DynamicResource ThemeText}"
                                         TextTrimming="CharacterEllipsis"/>
                              <TextBlock Text="{Binding PlaytimeLabel}"
                                         FontSize="10" Foreground="{DynamicResource ThemeText3}"/>
                            </StackPanel>
                          </Border>

                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ── Orbit mode ── -->
    <views:OrbitView x:Name="OrbitViewControl"
                     IsVisible="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=orbit}"
                     HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

    <!-- ─────────────────────────────────────────────────────────
         Floating nav pill — direct port of App.tsx 944-1156.
         Order: brand · All/Fav/Recent · plat-chips · filter ·
         view-toggle · theme-picker · layout-picker · add + settings.
         Detect / Chiaki / Xcloud are NOT on the nav in Electron —
         Detect is on the empty-state and Chiaki/Xcloud live on the
         bottom-right `.stream-pill`.
    ───────────────────────────────────────────────────────── -->
    <Border VerticalAlignment="{Binding ToolbarVerticalAlignment}" HorizontalAlignment="Center"
            Margin="0,8,0,8"
            CornerRadius="22"
            Background="#d20d0d16"
            BorderBrush="#17ffffff"
            BorderThickness="1"
            BoxShadow="0 8 32 0 #b3000000, inset 0 2 0 0 #0dffffff"
            Padding="10,4">
      <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">

        <!-- Brand "Cereal" — gradient matching index.css 126 -->
        <TextBlock Text="Cereal" FontSize="11" FontWeight="Light"
                   LetterSpacing="4"
                   VerticalAlignment="Center" Margin="6,0,10,0">
          <TextBlock.Foreground>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#d4a853" Offset="0"/>
              <GradientStop Color="#b0aaa0" Offset="1"/>
            </LinearGradientBrush>
          </TextBlock.Foreground>
        </TextBlock>

        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"/>

        <!-- Quick-filter chips: All / Fav / Recent (App.tsx 947-949) -->
        <Button Classes="chip" Content="All"
                Classes.active="{Binding QuickFilter, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=all}"
                Command="{Binding SetQuickFilterCommand}"
                CommandParameter="all"/>
        <Button Classes="chip" Content="Fav"
                Classes.active="{Binding QuickFilter, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=favorites}"
                Command="{Binding SetQuickFilterCommand}"
                CommandParameter="favorites"/>
        <Button Classes="chip" Content="Recent"
                Classes.active="{Binding QuickFilter, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=recent}"
                Command="{Binding SetQuickFilterCommand}"
                CommandParameter="recent"/>

        <!-- Platform chips (App.tsx 950-964): colored letter · label · count -->
        <ItemsControl ItemsSource="{Binding PlatformChips}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="1"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:PlatformChipViewModel">
              <Button Classes="chip"
                      Classes.active="{Binding IsActive}"
                      ToolTip.Tip="{Binding Label}"
                      Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).TogglePlatformFilterCommand}"
                      CommandParameter="{Binding Id}">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <!-- Colored letter badge stands in for the SVG icon each Electron chip has -->
                  <TextBlock Text="{Binding Letter}"
                             FontSize="11" FontWeight="Bold"
                             Width="14" Height="14"
                             TextAlignment="Center"
                             Foreground="{Binding Color, Converter={x:Static vm:ColorStringToBrushConverter.Instance}}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding Count}"
                             IsVisible="{Binding HasCount}"
                             FontSize="9" FontWeight="Medium"
                             Foreground="{DynamicResource ThemeText4}"
                             Margin="2,0,0,0"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"/>

        <!-- Sort / Filter flyout (with count badge, App.tsx 967-974) -->
        <Button Classes="nav-btn" ToolTip.Tip="Sort &amp; Filter">
          <Panel>
            <TextBlock Text="⚏" FontSize="14" VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
            <!-- Gold count badge top-right when any filter is active -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-4,-4,0" MinWidth="14" Height="14"
                    CornerRadius="7" Padding="3,0"
                    Background="{DynamicResource ThemeAccent}"
                    BoxShadow="0 4 12 0 #73000000"
                    IsVisible="{Binding HasActiveFilters}">
              <TextBlock Text="{Binding ActiveFilterCount}"
                         FontSize="8" FontWeight="Bold"
                         Foreground="{DynamicResource ThemeVoid}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Panel>
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <Border Background="{DynamicResource ThemeSurface}" BorderBrush="#1affffff" BorderThickness="1"
                      CornerRadius="10" Padding="16,14" MinWidth="220">
                <StackPanel Spacing="12">

                  <!-- Sort section -->
                  <TextBlock Text="SORT BY" FontSize="9" FontWeight="Bold"
                             LetterSpacing="1.5" Foreground="#40b0aaa0"/>
                  <WrapPanel Orientation="Horizontal">
                    <Button Content="Name" Margin="0,0,4,4" Padding="8,4" FontSize="10"
                            CornerRadius="6" BorderThickness="1" Cursor="Hand"
                            Command="{Binding SetSortCommand}" CommandParameter="name">
                      <Button.Styles>
                        <Style Selector="Button">
                          <Setter Property="Background" Value="#10ffffff"/>
                          <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
                          <Setter Property="BorderBrush" Value="#10ffffff"/>
                        </Style>
                      </Button.Styles>
                    </Button>
                    <Button Content="Most Played" Margin="0,0,4,4" Padding="8,4" FontSize="10"
                            CornerRadius="6" BorderThickness="1" Cursor="Hand"
                            Command="{Binding SetSortCommand}" CommandParameter="played">
                      <Button.Styles>
                        <Style Selector="Button">
                          <Setter Property="Background" Value="#10ffffff"/>
                          <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
                          <Setter Property="BorderBrush" Value="#10ffffff"/>
                        </Style>
                      </Button.Styles>
                    </Button>
                    <Button Content="Recent" Margin="0,0,4,4" Padding="8,4" FontSize="10"
                            CornerRadius="6" BorderThickness="1" Cursor="Hand"
                            Command="{Binding SetSortCommand}" CommandParameter="recent">
                      <Button.Styles>
                        <Style Selector="Button">
                          <Setter Property="Background" Value="#10ffffff"/>
                          <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
                          <Setter Property="BorderBrush" Value="#10ffffff"/>
                        </Style>
                      </Button.Styles>
                    </Button>
                    <Button Content="Added" Margin="0,0,4,4" Padding="8,4" FontSize="10"
                            CornerRadius="6" BorderThickness="1" Cursor="Hand"
                            Command="{Binding SetSortCommand}" CommandParameter="added">
                      <Button.Styles>
                        <Style Selector="Button">
                          <Setter Property="Background" Value="#10ffffff"/>
                          <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
                          <Setter Property="BorderBrush" Value="#10ffffff"/>
                        </Style>
                      </Button.Styles>
                    </Button>
                    <Button Content="Installed" Margin="0,0,4,4" Padding="8,4" FontSize="10"
                            CornerRadius="6" BorderThickness="1" Cursor="Hand"
                            Command="{Binding SetSortCommand}" CommandParameter="installed">
                      <Button.Styles>
                        <Style Selector="Button">
                          <Setter Property="Background" Value="#10ffffff"/>
                          <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
                          <Setter Property="BorderBrush" Value="#10ffffff"/>
                        </Style>
                      </Button.Styles>
                    </Button>
                  </WrapPanel>

                  <!-- Divider -->
                  <Border Height="1" Background="#0fffffff"/>

                  <!-- Show hidden toggle -->
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding ShowHidden}" Foreground="{DynamicResource ThemeText2}"/>
                    <TextBlock Text="Show hidden games" FontSize="12" Foreground="{DynamicResource ThemeText2}"
                               VerticalAlignment="Center"/>
                  </StackPanel>

                  <!-- Installed only -->
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding ShowInstalledOnly}" Foreground="{DynamicResource ThemeText2}"/>
                    <TextBlock Text="Installed only" FontSize="12" Foreground="{DynamicResource ThemeText2}"
                               VerticalAlignment="Center"/>
                  </StackPanel>

                  <!-- Category chips -->
                  <TextBlock Text="CATEGORIES" FontSize="9" FontWeight="Bold"
                             LetterSpacing="1.5" Foreground="#40b0aaa0"
                             IsVisible="{Binding AllCategories, Converter={x:Static conv:ObjectConverters.IsNotNull}}"/>
                  <ItemsControl ItemsSource="{Binding AllCategories}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Content="{Binding}" Margin="0,0,4,4" Padding="8,4" FontSize="10"
                                CornerRadius="6" BorderThickness="1" Cursor="Hand"
                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).ToggleCategoryFilterCommand}"
                                CommandParameter="{Binding}">
                          <Button.Styles>
                            <Style Selector="Button">
                              <Setter Property="Background" Value="#10ffffff"/>
                              <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
                              <Setter Property="BorderBrush" Value="#10ffffff"/>
                            </Style>
                          </Button.Styles>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <!-- Reset -->
                  <Button Content="Reset filters" FontSize="11" Padding="8,4"
                          CornerRadius="6" BorderThickness="1" Cursor="Hand"
                          HorizontalAlignment="Right"
                          Command="{Binding ClearFiltersCommand}">
                    <Button.Styles>
                      <Style Selector="Button">
                        <Setter Property="Background" Value="#10ffffff"/>
                        <Setter Property="Foreground" Value="{DynamicResource ThemeText3}"/>
                        <Setter Property="BorderBrush" Value="#10ffffff"/>
                      </Style>
                    </Button.Styles>
                  </Button>

                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- View toggle (App.tsx 1029-1032): orbit first, cards second -->
        <Border Padding="2" CornerRadius="8" Background="#08ffffff"
                BorderBrush="#0fffffff" BorderThickness="1"
                Margin="4,0">
          <StackPanel Orientation="Horizontal" Spacing="1">
            <Button Classes="view-btn"
                    Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=orbit}"
                    Command="{Binding SetViewModeCommand}"
                    CommandParameter="orbit"
                    ToolTip.Tip="Orbit view">
              <TextBlock Text="◉" FontSize="12"/>
            </Button>
            <Button Classes="view-btn"
                    Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}"
                    Command="{Binding SetViewModeCommand}"
                    CommandParameter="cards"
                    ToolTip.Tip="Card view">
              <TextBlock Text="⊞" FontSize="12"/>
            </Button>
          </StackPanel>
        </Border>

        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"/>

        <!-- Theme picker (App.tsx 1034-1091) — dots + custom accent input -->
        <Button Classes="nav-btn" ToolTip.Tip="Theme">
          <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <Ellipse Width="10" Height="10" Fill="{DynamicResource ThemeAccent}"/>
            <TextBlock Text="▾" FontSize="8" VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeText3}"/>
          </StackPanel>
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <Border Background="{DynamicResource ThemeSurface}"
                      BorderBrush="#1affffff" BorderThickness="1"
                      CornerRadius="12" Padding="10">
                <StackPanel Spacing="6" Width="140">
                  <ItemsControl ItemsSource="{Binding ThemeSwatches}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ThemeSwatchViewModel">
                        <Button Width="22" Height="22" Margin="3"
                                Background="{Binding AccentBrush}"
                                BorderBrush="{Binding BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="11"
                                ToolTip.Tip="{Binding Label}"
                                Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).SetThemeCommand}"
                                CommandParameter="{Binding Id}"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Border Height="1" Background="#14ffffff"/>
                  <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBox Grid.Column="0" Text="{Binding AccentColor}"
                             Watermark="#d4a853"
                             Background="#0affffff" BorderBrush="#18ffffff"
                             Foreground="{DynamicResource ThemeText}"
                             CornerRadius="5" Padding="6,3" FontSize="10"/>
                    <TextBlock Grid.Column="1" Text="Accent" FontSize="9"
                               Margin="6,0,0,0" Foreground="#50b0aaa0"
                               VerticalAlignment="Center"/>
                  </Grid>
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- Toolbar position picker (port of App.tsx 1122–1150) -->
        <Button Classes="nav-btn" ToolTip.Tip="Toolbar position">
          <TextBlock Text="⚏" FontSize="13" VerticalAlignment="Center"
                     HorizontalAlignment="Center"/>
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <Border Background="{DynamicResource ThemeSurface}"
                      BorderBrush="#1affffff" BorderThickness="1"
                      CornerRadius="10" Padding="6">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Button Classes="nav-btn" ToolTip.Tip="Top"
                          Command="{Binding SetToolbarPositionCommand}" CommandParameter="top">
                    <TextBlock Text="▁" FontSize="14"/>
                  </Button>
                  <Button Classes="nav-btn" ToolTip.Tip="Bottom"
                          Command="{Binding SetToolbarPositionCommand}" CommandParameter="bottom">
                    <TextBlock Text="▔" FontSize="14"/>
                  </Button>
                  <Button Classes="nav-btn" ToolTip.Tip="Left"
                          Command="{Binding SetToolbarPositionCommand}" CommandParameter="left">
                    <TextBlock Text="▏" FontSize="14"/>
                  </Button>
                  <Button Classes="nav-btn" ToolTip.Tip="Right"
                          Command="{Binding SetToolbarPositionCommand}" CommandParameter="right">
                    <TextBlock Text="▕" FontSize="14"/>
                  </Button>
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"/>

        <!-- Trailing nav-actions: Add + Settings (App.tsx 1152-1155) -->
        <Button Classes="nav-btn" ToolTip.Tip="Add game"
                Command="{Binding ShowAddGameCommand}">
          <TextBlock Text="＋" FontSize="15" VerticalAlignment="Center"
                     HorizontalAlignment="Center"/>
        </Button>
        <Button Classes="nav-btn" ToolTip.Tip="Settings (Ctrl+,)"
                Command="{Binding OpenSettingsCommand}">
          <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center"
                     HorizontalAlignment="Center"/>
        </Button>

      </StackPanel>
    </Border>

    <!-- ─────────────────────────────────────────────────────────
         Stream pill (App.tsx 922-935) — floats bottom-right only
         in cards mode and only offers the two streamable platforms.
         Remote Play opens the Chiaki panel; Cloud Gaming opens the
         xCloud panel. Detect / Connect live in the empty state and
         Settings panel respectively; they deliberately do NOT have
         a dedicated nav-pill button in the Electron original.
    ───────────────────────────────────────────────────────── -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
            Margin="0,0,16,16"
            CornerRadius="22" Padding="6,4"
            Background="#d20d0d16"
            BorderBrush="#17ffffff" BorderThickness="1"
            BoxShadow="0 8 32 0 #b3000000, inset 0 2 0 0 #0dffffff"
            ZIndex="50"
            IsVisible="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}">
      <StackPanel Orientation="Horizontal" Spacing="2">
        <Button Classes="stream-pill-btn" ToolTip.Tip="PlayStation Remote Play"
                Command="{Binding OpenChiakiCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Width="22" Height="22" CornerRadius="11"
                    Background="#33003087"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="P" FontSize="11" FontWeight="Bold"
                         Foreground="#4d8fff"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Remote Play" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Classes="stream-pill-btn" ToolTip.Tip="Xbox Cloud Gaming"
                Command="{Binding OpenXcloudCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Width="22" Height="22" CornerRadius="11"
                    Background="#33107c10"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="X" FontSize="11" FontWeight="Bold"
                         Foreground="#34d399"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Cloud Gaming" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- ── Status bar (cover download progress) ── -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
            Margin="0,0,0,20"
            CornerRadius="20" Padding="14,6"
            Background="#d20d0d16"
            IsVisible="{Binding StatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
      <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
    </Border>

    <!-- ── Subtle progress pill (bottom-right) — mirrors Electron's subtle-pill ── -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
            Margin="0,0,22,22" CornerRadius="14" Padding="12,8"
            Background="#ec0d0d16" BorderBrush="#18ffffff" BorderThickness="1"
            MinWidth="220"
            BoxShadow="0 8 24 0 #80000000"
            IsVisible="{Binding ShowProgressPill}">
      <StackPanel Spacing="6">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <!-- Spinner (inactive) / check (done) -->
          <Border Width="14" Height="14" CornerRadius="7"
                  Background="{DynamicResource ThemeAccent}"
                  IsVisible="{Binding ProgressPillDone}">
            <TextBlock Text="✓" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeVoid}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <Border Width="14" Height="14" CornerRadius="7"
                  BorderBrush="{DynamicResource ThemeAccent}" BorderThickness="2"
                  IsVisible="{Binding !ProgressPillDone}"/>

          <TextBlock Text="{Binding ProgressPillText}" FontSize="11"
                     Foreground="{DynamicResource ThemeText2}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <ProgressBar Minimum="0" Maximum="1" Height="3"
                     Value="{Binding ProgressPillPercent}"
                     Background="#14ffffff"
                     Foreground="{DynamicResource ThemeAccent}"
                     CornerRadius="2"
                     IsVisible="{Binding !ProgressPillDone}"/>
      </StackPanel>
    </Border>

  </Panel>

</UserControl>
