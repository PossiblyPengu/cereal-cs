<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cereal.App.ViewModels"
             xmlns:conv="using:Cereal.App"
             xmlns:views="using:Cereal.App.Views"
             x:Class="Cereal.App.Views.MainView"
             x:DataType="vm:MainViewModel"
             Classes.no-motion="{Binding UiAnimationsDisabled}"
             Background="{DynamicResource ThemeVoid}">

  <UserControl.Resources>
    <DataTemplate x:Key="GameCardDataTemplate" x:DataType="vm:GameCardViewModel">
      <Border Classes="game-card" Width="150"
              Classes.not-installed="{Binding IsNotInstalled}"
              Focusable="True"
              Tapped="Card_Tapped"
              DoubleTapped="Card_DoubleTapped"
              KeyDown="Card_KeyDown">
        <Grid RowDefinitions="225,Auto">
          <Panel Grid.Row="0">
            <Border Background="{DynamicResource ThemeCardUp}">
              <TextBlock Text="{Binding Initial}" FontSize="36" FontWeight="UltraLight" Foreground="#4d706b63"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Image Source="{Binding CoverPath, Converter={x:Static vm:CoverThumbConverter.Instance}}"
                   Stretch="UniformToFill"
                   IsVisible="{Binding HasCover}"/>
            <Border VerticalAlignment="Bottom" Height="80" IsHitTestVisible="False">
              <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                  <GradientStop Color="Transparent" Offset="0"/>
                  <GradientStop Color="#b202020c" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
            </Border>
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" CornerRadius="4" Padding="6,2" Background="#8c000000">
              <Panel MinHeight="12">
                <Viewbox Width="14" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding ShowPlatformLogoFill}">
                  <Canvas Width="24" Height="24">
                    <Path Fill="{Binding PlatformColor, Converter={x:Static vm:ColorStringToBrushConverter.Instance}}"
                          Data="{Binding PlatformLogoPath}"/>
                  </Canvas>
                </Viewbox>
                <Viewbox Width="14" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding ShowPlatformLogoStroke}">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{Binding PlatformColor, Converter={x:Static vm:ColorStringToBrushConverter.Instance}}"
                          StrokeThickness="{Binding PlatformLogoStrokeWidth}"
                          StrokeLineCap="Round"
                          Fill="Transparent"
                          Data="{Binding PlatformLogoPath}"/>
                  </Canvas>
                </Viewbox>
                <TextBlock Text="{Binding PlatformLetter}" FontSize="9" FontWeight="Bold"
                           Foreground="{Binding PlatformColor, Converter={x:Static vm:ColorStringToBrushConverter.Instance}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding ShowPlatformLetter}"/>
              </Panel>
            </Border>
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Width="22" Height="22"
                    CornerRadius="11" Background="{DynamicResource ThemeAccent}" BoxShadow="0 2 8 0 #4cd4a853" IsVisible="{Binding IsFavorite}">
              <PathIcon Width="10" Height="10"
                        Foreground="#0a0a0f"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Data="M12,2 L15.09,8.26 L22,9.27 L17,14.14 L18.18,21.02 L12,17.77 L5.82,21.02 L7,14.14 L2,9.27 L8.91,8.26 Z"/>
            </Border>
            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8" Width="22" Height="22"
                    CornerRadius="11" Background="#bf000000" BorderBrush="#26ffffff" BorderThickness="1"
                    IsVisible="{Binding IsNotInstalled}">
              <PathIcon Width="10" Height="10"
                        Foreground="#99ffffff"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Data="M12,3 V15 M7,10 L12,15 L17,10 M3,19 H21"/>
            </Border>
            <Border Classes="hover-actions" VerticalAlignment="Bottom" IsHitTestVisible="False">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6" Margin="8,8">
                <Button Classes="btn-play-hover" Content="Play" IsHitTestVisible="True" Click="PlayBtn_Click"/>
                <Button Classes="btn-ghost-hover" Content="{Binding FavoriteLabel}" IsHitTestVisible="True" Click="FavBtn_Click"/>
              </StackPanel>
            </Border>
          </Panel>
          <Border Grid.Row="1" Padding="10,10,10,12">
            <StackPanel Spacing="3">
              <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}" TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="{Binding PlaytimeLabel}" FontSize="10" Foreground="{DynamicResource ThemeText3}"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <UserControl.DataTemplates>
    <DataTemplate x:DataType="vm:PlatformSectionRowViewModel">
      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="{Binding SectionMargin}">
        <Ellipse Width="8" Height="8" Fill="{Binding PlatformColor}" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding PlatformLabel}" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeText2}" LetterSpacing="0.5" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding CountLabel}" FontSize="11" FontWeight="Normal"
                   Foreground="{DynamicResource ThemeText4}" VerticalAlignment="Center"/>
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:DataType="vm:GameCardRowViewModel">
      <ItemsControl ItemsSource="{Binding Cards}" ItemTemplate="{StaticResource GameCardDataTemplate}" Margin="{Binding RowMargin}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" Spacing="14"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
      </ItemsControl>
    </DataTemplate>
  </UserControl.DataTemplates>

  <UserControl.Styles>

    <!-- â”€â”€ Nav pill chip â”€â”€ -->
    <Style Selector="Button.chip">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText3}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Padding" Value="12,4"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.chip:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#0bffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText2}"/>
    </Style>
    <Style Selector="Button.chip:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#14ffffff"/>
    </Style>
    <Style Selector="Button.chip:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.chip:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>
    <!-- index.css .chip.active â€” rgba(212,168,83,0.12) accent-soft -->
    <Style Selector="Button.chip.active">
      <Setter Property="Background" Value="{DynamicResource ThemeAccentSoft}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeFocusRingColor}"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
    </Style>
    <!-- Side rail: same thickness as top/bottom bar; chips must stay within the fixed width. -->
    <Style Selector="Border.rail > StackPanel > Button.chip">
      <Setter Property="Width" Value="30"/>
      <Setter Property="Padding" Value="2,3"/>
      <Setter Property="FontSize" Value="8"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.rail > StackPanel > Panel">
      <Setter Property="Margin" Value="0"/>
    </Style>
    <Style Selector="Border.rail > StackPanel > Button.theme-picker-btn">
      <Setter Property="Width" Value="30"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Padding" Value="3,3"/>
    </Style>
    <Style Selector="Border.rail > StackPanel">
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <!-- â”€â”€ Nav pill icon button â”€â”€ -->
    <Style Selector="Button.nav-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText3}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="30"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#0bffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>
    <Style Selector="Button.nav-btn:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#18ffffff"/>
    </Style>
    <Style Selector="Button.nav-btn:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.nav-btn:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>

    <!-- index.css .theme-picker-btn -->
    <Style Selector="Button.theme-picker-btn">
      <Setter Property="Background" Value="#0affffff"/>
      <Setter Property="BorderBrush" Value="#0fffffff"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="9,5"/>
      <Setter Property="MinHeight" Value="26"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.theme-picker-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#12ffffff"/>
      <Setter Property="BorderBrush" Value="#1affffff"/>
    </Style>
    <Style Selector="Button.theme-picker-btn:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#18ffffff"/>
    </Style>
    <Style Selector="Button.theme-picker-btn:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>

    <!-- â”€â”€ View toggle button â”€â”€ -->
    <Style Selector="Button.view-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText4}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="26"/>
      <Setter Property="Height" Value="26"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.view-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#0affffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText2}"/>
    </Style>
    <Style Selector="Button.view-btn:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#14ffffff"/>
    </Style>
    <Style Selector="Button.view-btn:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.view-btn:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>
    <Style Selector="Button.view-btn.active">
      <Setter Property="Background" Value="{DynamicResource ThemeAccentSoft}"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
    </Style>

    <!-- â”€â”€ Game card (index.css .game-card) â”€â”€ -->
    <Style Selector="Border.game-card">
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Background" Value="{DynamicResource ThemeCard}"/>
      <Setter Property="BorderBrush" Value="#0fffffff"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="ClipToBounds" Value="True"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="RenderTransform" Value="scale(1) translateY(0px)"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.32"/>
          <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.32"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.32"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.game-card:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.02) translateY(-4px)"/>
      <Setter Property="BoxShadow" Value="0 12 32 0 #66000000"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeFocusRingColor}"/>
    </Style>
    <Style Selector="Border.game-card:focus">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>
    <!-- index.css .game-card:hover .card-cover img -->
    <Style Selector="Border.game-card Image">
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.32"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.game-card:pointerover Image">
      <Setter Property="RenderTransform" Value="scale(1.05)"/>
    </Style>

    <!-- Not-installed: dimmed -->
    <!-- index.css .game-card.not-installed â€” opacity 0.6 -->
    <Style Selector="Border.game-card.not-installed">
      <Setter Property="Opacity" Value="0.6"/>
    </Style>
    <Style Selector="Border.game-card.not-installed:pointerover">
      <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <!-- Hover actions: hidden by default, visible on card hover -->
    <Style Selector="Border.game-card Panel Border.hover-actions">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.game-card:pointerover Panel Border.hover-actions">
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- Search box -->
    <Style Selector="TextBox.search">
      <Setter Property="Background" Value="#08ffffff"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentSoft}"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource ThemeAccent}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="MinWidth" Value="160"/>
    </Style>
    <Style Selector="TextBox.search:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeFocusRingColor}"/>
    </Style>

    <!-- â”€â”€ Stream pill button (index.css 707-710) â”€â”€ -->
    <Style Selector="Button.stream-pill-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText3}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.stream-pill-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#0fffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>
    <Style Selector="Button.stream-pill-btn:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#20ffffff"/>
    </Style>
    <Style Selector="Button.stream-pill-btn:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.stream-pill-btn:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>

    <!-- Play / ghost hover buttons â€” .card-hover-btn (index.css 806-810) -->
    <Style Selector="Button.btn-play-hover">
      <Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
      <Setter Property="Foreground" Value="#0a0a0f"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.btn-play-hover:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ThemeAccentHover}"/>
    </Style>
    <Style Selector="Button.btn-play-hover:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ThemeAccentPressed}"/>
    </Style>
    <Style Selector="Button.btn-play-hover:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.btn-play-hover:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>
    <Style Selector="Button.btn-ghost-hover">
      <Setter Property="Background" Value="#14ffffff"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="BorderBrush" Value="#14ffffff"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.btn-ghost-hover:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#20ffffff"/>
      <Setter Property="BorderBrush" Value="#1affffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>
    <Style Selector="Button.btn-ghost-hover:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#28ffffff"/>
    </Style>
    <Style Selector="Button.btn-ghost-hover:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45"/>
    </Style>
    <Style Selector="Button.btn-ghost-hover:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>

    <!-- â”€â”€ Filter flyout buttons (sort + categories) â”€â”€ -->
    <Style Selector="Button.filter-btn">
      <Setter Property="Background" Value="#10ffffff"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText2}"/>
      <Setter Property="BorderBrush" Value="#10ffffff"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.filter-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#18ffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>
    <Style Selector="Button.filter-btn:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#22ffffff"/>
    </Style>
    <Style Selector="Button.filter-btn:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>
    <Style Selector="Button.filter-btn.active">
      <Setter Property="Background" Value="{DynamicResource ThemeAccentSoft}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeFocusRingColor}"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
    </Style>

    <!-- Remove default flyout presenter plate behind custom dropdown content -->
    <Style Selector="FlyoutPresenter">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <!-- Respect the global Show animations setting for the library surface. -->
    <Style Selector="UserControl.no-motion Border.game-card">
      <Setter Property="Transitions">
        <Transitions/>
      </Setter>
    </Style>
    <Style Selector="UserControl.no-motion Border.game-card:pointerover">
      <Setter Property="RenderTransform" Value="scale(1) translateY(0px)"/>
      <Setter Property="BoxShadow" Value="{x:Null}"/>
      <Setter Property="BorderBrush" Value="#0fffffff"/>
    </Style>
    <Style Selector="UserControl.no-motion Border.game-card Image">
      <Setter Property="Transitions">
        <Transitions/>
      </Setter>
    </Style>
    <Style Selector="UserControl.no-motion Border.game-card:pointerover Image">
      <Setter Property="RenderTransform" Value="scale(1)"/>
    </Style>
    <Style Selector="UserControl.no-motion Border.game-card Panel Border.hover-actions">
      <Setter Property="Transitions">
        <Transitions/>
      </Setter>
    </Style>

    <!-- â”€â”€ Cards view fade-in on enter (#10) â”€â”€ -->
    <Style Selector="Panel.cards-view">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Panel.cards-view.active">
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="UserControl.no-motion Panel.cards-view">
      <Setter Property="Transitions"><Transitions/></Setter>
    </Style>

  </UserControl.Styles>

  <!-- Root panel â€” content + floating nav pill -->
  <Panel>

    <!-- â”€â”€ Card grid (scroll area) â”€â”€ -->
    <!-- Outer Panel: empty-state overlay; scroll has one virtualized list of
         section headers + short horizontal card rows. -->
    <Panel Classes="cards-view"
           Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}"
           IsVisible="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}">

      <!-- Empty state overlay â€” centered, only shown when library is empty -->
      <StackPanel IsVisible="{Binding !VisibleGames.Count}"
                  VerticalAlignment="Center" HorizontalAlignment="Center"
                  IsHitTestVisible="{Binding !VisibleGames.Count}"
                  Spacing="14">
        <TextBlock Text=":/" FontSize="48" Foreground="#33e8e4de"
                   FontWeight="Light" LetterSpacing="4"
                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
        <TextBlock Text="No games yet" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeText3}" HorizontalAlignment="Center"/>
        <TextBlock Text="Add games manually or detect from installed platforms."
                   FontSize="13" Foreground="{DynamicResource ThemeText4}"
                   HorizontalAlignment="Center" MaxWidth="320"
                   TextWrapping="Wrap" TextAlignment="Center"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center"
                    Margin="0,6,0,0">
          <Button Content="Add Game"
                  Background="{DynamicResource ThemeAccent}" Foreground="{DynamicResource ThemeOnAccent}"
                  CornerRadius="10" Padding="20,9" FontSize="13" FontWeight="Bold"
                  BorderThickness="0" Cursor="Hand"
                  Command="{Binding ShowAddGameCommand}"/>
          <Button Content="Detect"
                  Background="Transparent" Foreground="{DynamicResource ThemeText2}"
                  BorderBrush="#1affffff" BorderThickness="1"
                  CornerRadius="10" Padding="20,9" FontSize="13"
                  Cursor="Hand"
                  Command="{Binding OpenDetectCommand}"/>
        </StackPanel>
      </StackPanel>

      <ScrollViewer x:Name="LibraryScroll" HorizontalScrollBarVisibility="Disabled"
                    ScrollChanged="LibraryScroll_ScrollChanged">
        <ItemsControl ItemsSource="{Binding CardLayoutRows}" Margin="32,52,32,34">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel Orientation="Vertical"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>
      </ScrollViewer>

    </Panel>

    <!-- â”€â”€ Orbit mode â”€â”€ -->
    <views:OrbitView x:Name="OrbitViewControl"
                     IsVisible="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=orbit}"
                     HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

    <!-- â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
         Floating nav pill â€” direct port of App.tsx 944-1156.
         Order: brand Â· All/Fav/Recent Â· plat-chips Â· filter Â·
         view-toggle Â· theme-picker Â· layout-picker Â· add + settings.
         Detect / Chiaki / Xcloud are NOT on the nav in Electron â€”
         Detect is on the empty-state and Chiaki/Xcloud live on the
         bottom-right `.stream-pill`.
    â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <!-- index.css .nav-pill â€” rgba(13,13,22,0.82), border rgba(255,255,255,0.09) -->
    <Border Classes.rail="{Binding IsSideNav}"
            VerticalAlignment="{Binding ToolbarVerticalAlignment}"
            HorizontalAlignment="{Binding ToolbarHorizontalAlignment}"
            Margin="{Binding ToolbarMargin}"
            Width="{Binding NavPillWidth}"
            MinWidth="{Binding NavPillMinWidth}"
            MinHeight="{Binding NavPillMinHeight}"
            CornerRadius="{Binding NavPillCornerRadius}"
            ClipToBounds="{Binding IsSideNav}"
            Background="{DynamicResource ThemeSurface}"
            BorderBrush="#17ffffff"
            BorderThickness="1"
            BoxShadow="0 8 32 0 #b3000000, 0 2 8 0 #80000000, inset 0 2 0 0 #0dffffff"
            Padding="{Binding NavPillPadding}"
            RenderTransformOrigin="0.5,0.5">
      <Border.RenderTransform>
        <ScaleTransform ScaleX="{Binding ToolbarScale}" ScaleY="{Binding ToolbarScale}"/>
      </Border.RenderTransform>
      <StackPanel Orientation="{Binding ToolbarOrientation}" Spacing="2" VerticalAlignment="Center">

        <!-- Brand â€” horizontal on top/bottom, vertical on left/right -->
        <Panel Margin="6,0,10,0" VerticalAlignment="Center">
          <TextBlock Text="CEREAL" FontSize="11" FontWeight="Light"
                     LetterSpacing="4" VerticalAlignment="Center"
                     IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=top}">
            <TextBlock.Foreground>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{DynamicResource ThemeAccentColor}" Offset="0"/>
                <GradientStop Color="#b0aaa0" Offset="1"/>
              </LinearGradientBrush>
            </TextBlock.Foreground>
          </TextBlock>
          <TextBlock Text="CEREAL" FontSize="11" FontWeight="Light"
                     LetterSpacing="4" VerticalAlignment="Center"
                     IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=bottom}">
            <TextBlock.Foreground>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{DynamicResource ThemeAccentColor}" Offset="0"/>
                <GradientStop Color="#b0aaa0" Offset="1"/>
              </LinearGradientBrush>
            </TextBlock.Foreground>
          </TextBlock>
          <TextBlock Text="C&#10;E&#10;R&#10;E&#10;A&#10;L" FontSize="11" FontWeight="Light"
                     LetterSpacing="1.5" VerticalAlignment="Center"
                     IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=left}">
            <TextBlock.Foreground>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{DynamicResource ThemeAccentColor}" Offset="0"/>
                <GradientStop Color="#b0aaa0" Offset="1"/>
              </LinearGradientBrush>
            </TextBlock.Foreground>
          </TextBlock>
          <TextBlock Text="C&#10;E&#10;R&#10;E&#10;A&#10;L" FontSize="11" FontWeight="Light"
                     LetterSpacing="1.5" VerticalAlignment="Center"
                     IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=right}">
            <TextBlock.Foreground>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{DynamicResource ThemeAccentColor}" Offset="0"/>
                <GradientStop Color="#b0aaa0" Offset="1"/>
              </LinearGradientBrush>
            </TextBlock.Foreground>
          </TextBlock>
        </Panel>

        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=top}"/>
        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=bottom}"/>
        <Border Width="16" Height="1" Background="#0fffffff" Margin="0,4"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=left}"/>
        <Border Width="16" Height="1" Background="#0fffffff" Margin="0,4"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=right}"/>

        <!-- Quick-filter chips: All / Fav / Recent (App.tsx 947-949) -->
        <Button Classes="chip" Content="All"
                Classes.active="{Binding QuickFilter, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=all}"
                Command="{Binding SetQuickFilterCommand}"
                CommandParameter="all"/>
        <Button Classes="chip" Content="Fav"
                Classes.active="{Binding QuickFilter, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=favorites}"
                Command="{Binding SetQuickFilterCommand}"
                CommandParameter="favorites"/>
        <Button Classes="chip" Content="Recent"
                Classes.active="{Binding QuickFilter, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=recent}"
                Command="{Binding SetQuickFilterCommand}"
                CommandParameter="recent"/>

        <!-- Filter flyout â€” trigger icon matches Vite I.search (constants.tsx) -->
        <Button Classes="nav-btn" ToolTip.Tip="Filter games" ClipToBounds="False">
          <Panel ClipToBounds="False">
            <Viewbox Width="14" Height="14">
              <Canvas Width="24" Height="24">
                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="2"
                      StrokeLineCap="Round"
                      Fill="Transparent"
                      Data="M19,11 A8,8 0 1 1 3,11 A8,8 0 1 1 19,11 M21,21 L16.65,16.65"/>
              </Canvas>
            </Viewbox>
            <!-- Gold count badge top-right when any filter is active -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-4,-4,0" MinWidth="14" Height="14"
                    CornerRadius="7" Padding="3,0"
                    Background="{DynamicResource ThemeAccent}"
                    BoxShadow="0 4 12 0 #73000000"
                    IsVisible="{Binding HasActiveFilters}">
              <TextBlock Text="{Binding ActiveFilterCount}"
                         FontSize="8" FontWeight="Bold"
                         Foreground="{DynamicResource ThemeOnAccent}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Panel>
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <Border Background="{DynamicResource ThemeSurface}" BorderBrush="#0fffffff" BorderThickness="1"
                      CornerRadius="10" Padding="16,14" MinWidth="320" MaxWidth="420"
                      BoxShadow="0 12 40 0 #cc000000, 0 4 12 0 #66000000">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="540">
                <StackPanel Spacing="12">

                  <!-- Sort section -->
                  <TextBlock Text="SORT BY" FontSize="9" FontWeight="Bold"
                             LetterSpacing="1.5" Foreground="#60b0aaa0"/>
                  <WrapPanel Orientation="Horizontal">
                    <Button Classes="filter-btn" Content="Name" Margin="0,0,4,4"
                            Classes.active="{Binding SortOrder, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=name}"
                            Command="{Binding SetSortCommand}" CommandParameter="name"/>
                    <Button Classes="filter-btn" Content="Most Played" Margin="0,0,4,4"
                            Classes.active="{Binding SortOrder, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=played}"
                            Command="{Binding SetSortCommand}" CommandParameter="played"/>
                    <Button Classes="filter-btn" Content="Recent" Margin="0,0,4,4"
                            Classes.active="{Binding SortOrder, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=recent}"
                            Command="{Binding SetSortCommand}" CommandParameter="recent"/>
                    <Button Classes="filter-btn" Content="Added" Margin="0,0,4,4"
                            Classes.active="{Binding SortOrder, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=added}"
                            Command="{Binding SetSortCommand}" CommandParameter="added"/>
                    <Button Classes="filter-btn" Content="Installed" Margin="0,0,4,4"
                            Classes.active="{Binding SortOrder, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=installed}"
                            Command="{Binding SetSortCommand}" CommandParameter="installed"/>
                  </WrapPanel>

                  <!-- Divider -->
                  <Border Height="1" Background="#0fffffff"/>

                  <!-- Text filter (parity with source gameFilter in filter popover) -->
                  <StackPanel Spacing="4">
                    <TextBlock Text="SEARCH" FontSize="9" FontWeight="Bold"
                               LetterSpacing="1.5" Foreground="#60b0aaa0"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                      <TextBox Grid.Column="0"
                               Text="{Binding SearchText}" Watermark="Filter games..."
                               Background="#0affffff" BorderBrush="#18ffffff"
                               Foreground="{DynamicResource ThemeText}"
                               CornerRadius="6" Padding="8,5" FontSize="11"/>
                      <Button Grid.Column="1"
                              Classes="filter-btn"
                              Content="Clear"
                              Command="{Binding ClearSearchTextCommand}"
                              IsVisible="{Binding SearchText, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"/>
                    </Grid>
                  </StackPanel>

                  <!-- Show hidden toggle -->
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding ShowHidden}" Foreground="{DynamicResource ThemeText2}"/>
                    <TextBlock Text="Show hidden games" FontSize="12" Foreground="{DynamicResource ThemeText2}"
                               VerticalAlignment="Center"/>
                  </StackPanel>

                  <!-- Installed only -->
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding ShowInstalledOnly}" Foreground="{DynamicResource ThemeText2}"/>
                    <TextBlock Text="Installed only" FontSize="12" Foreground="{DynamicResource ThemeText2}"
                               VerticalAlignment="Center"/>
                  </StackPanel>

                  <!-- Hide steam software/tools -->
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding HideSteamSoftware}" Foreground="{DynamicResource ThemeText2}"/>
                    <TextBlock Text="Hide Steam software" FontSize="12" Foreground="{DynamicResource ThemeText2}"
                               VerticalAlignment="Center"/>
                  </StackPanel>

                  <!-- Category chips -->
                  <TextBlock Text="PLATFORMS" FontSize="9" FontWeight="Bold"
                             LetterSpacing="1.5" Foreground="#60b0aaa0"/>
                  <ItemsControl ItemsSource="{Binding PlatformChips}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:PlatformChipViewModel">
                        <Button Classes="filter-btn" Margin="0,0,4,4"
                                Classes.active="{Binding IsActive}"
                                ToolTip.Tip="{Binding Label}"
                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).TogglePlatformFilterCommand}"
                                CommandParameter="{Binding Id}">
                          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Panel Width="14" Height="14" VerticalAlignment="Center">
                              <Viewbox Width="14" Height="14" IsVisible="{Binding ShowLogoFill}">
                                <Canvas Width="24" Height="24">
                                  <Path Fill="{Binding Color, Converter={x:Static vm:ColorStringToBrushConverter.Instance}}"
                                        Data="{Binding LogoPathData}"/>
                                </Canvas>
                              </Viewbox>
                              <Viewbox Width="14" Height="14" IsVisible="{Binding ShowLogoStroke}">
                                <Canvas Width="24" Height="24">
                                  <Path Stroke="{Binding Color, Converter={x:Static vm:ColorStringToBrushConverter.Instance}}"
                                        StrokeThickness="{Binding LogoStrokeWidth}"
                                        StrokeLineCap="Round"
                                        Fill="Transparent"
                                        Data="{Binding LogoPathData}"/>
                                </Canvas>
                              </Viewbox>
                              <TextBlock Text="{Binding Letter}" FontSize="9" FontWeight="Bold"
                                         Foreground="{Binding Color, Converter={x:Static vm:ColorStringToBrushConverter.Instance}}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                         IsVisible="{Binding ShowLogoLetter}"/>
                            </Panel>
                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Count}"
                                       IsVisible="{Binding HasCount}"
                                       FontSize="9" FontWeight="Medium"
                                       Foreground="{DynamicResource ThemeText4}"
                                       Margin="2,0,0,0"
                                       VerticalAlignment="Center"/>
                          </StackPanel>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <TextBlock Text="CATEGORIES" FontSize="9" FontWeight="Bold"
                             LetterSpacing="1.5" Foreground="#60b0aaa0"
                             IsVisible="{Binding AllCategories, Converter={x:Static conv:ObjectConverters.IsNotNull}}"/>
                  <ItemsControl ItemsSource="{Binding AllCategories}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Classes="filter-btn" Content="{Binding}" Margin="0,0,4,4"
                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).ToggleCategoryFilterCommand}"
                                CommandParameter="{Binding}"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <!-- Reset -->
                  <Button Classes="filter-btn" Content="Reset filters"
                          HorizontalAlignment="Right"
                          Command="{Binding ClearFiltersCommand}"/>

                </StackPanel>
                </ScrollViewer>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- View toggle (App.tsx 1029-1032): compact variant for side rails -->
        <Panel>
          <Border Padding="2" CornerRadius="8" Background="#0bffffff"
                  BorderBrush="#0fffffff" BorderThickness="1"
                  Margin="4,0"
                  IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=top}">
            <StackPanel Orientation="Horizontal" Spacing="1">
              <Button Classes="view-btn"
                      Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=orbit}"
                      Command="{Binding SetViewModeCommand}"
                      CommandParameter="orbit"
                      ToolTip.Tip="Orbit view">
                <Viewbox Width="12" Height="12">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          Fill="Transparent"
                          Data="M15,12 A3,3 0 1 1 9,12 A3,3 0 1 1 15,12 M21,12 A9,9 0 1 1 3,12 A9,9 0 1 1 21,12"/>
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="view-btn"
                      Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}"
                      Command="{Binding SetViewModeCommand}"
                      CommandParameter="cards"
                      ToolTip.Tip="Card view">
                <Viewbox Width="12" Height="12">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          Fill="Transparent"
                          Data="M4,3 H9 A1,1 0 0 1 10,4 V9 A1,1 0 0 1 9,10 H4 A1,1 0 0 1 3,9 V4 A1,1 0 0 1 4,3 Z M15,3 H20 A1,1 0 0 1 21,4 V9 A1,1 0 0 1 20,10 H15 A1,1 0 0 1 14,9 V4 A1,1 0 0 1 15,3 Z M4,14 H9 A1,1 0 0 1 10,15 V20 A1,1 0 0 1 9,21 H4 A1,1 0 0 1 3,20 V15 A1,1 0 0 1 4,14 Z M15,14 H20 A1,1 0 0 1 21,15 V20 A1,1 0 0 1 20,21 H15 A1,1 0 0 1 14,20 V15 A1,1 0 0 1 15,14 Z"/>
                  </Canvas>
                </Viewbox>
              </Button>
            </StackPanel>
          </Border>
          <Border Padding="2" CornerRadius="8" Background="#0bffffff"
                  BorderBrush="#0fffffff" BorderThickness="1"
                  Margin="4,0"
                  IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=bottom}">
            <StackPanel Orientation="Horizontal" Spacing="1">
              <Button Classes="view-btn"
                      Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=orbit}"
                      Command="{Binding SetViewModeCommand}"
                      CommandParameter="orbit"
                      ToolTip.Tip="Orbit view">
                <Viewbox Width="12" Height="12">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          Fill="Transparent"
                          Data="M15,12 A3,3 0 1 1 9,12 A3,3 0 1 1 15,12 M21,12 A9,9 0 1 1 3,12 A9,9 0 1 1 21,12"/>
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="view-btn"
                      Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}"
                      Command="{Binding SetViewModeCommand}"
                      CommandParameter="cards"
                      ToolTip.Tip="Card view">
                <Viewbox Width="12" Height="12">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          Fill="Transparent"
                          Data="M4,3 H9 A1,1 0 0 1 10,4 V9 A1,1 0 0 1 9,10 H4 A1,1 0 0 1 3,9 V4 A1,1 0 0 1 4,3 Z M15,3 H20 A1,1 0 0 1 21,4 V9 A1,1 0 0 1 20,10 H15 A1,1 0 0 1 14,9 V4 A1,1 0 0 1 15,3 Z M4,14 H9 A1,1 0 0 1 10,15 V20 A1,1 0 0 1 9,21 H4 A1,1 0 0 1 3,20 V15 A1,1 0 0 1 4,14 Z M15,14 H20 A1,1 0 0 1 21,15 V20 A1,1 0 0 1 20,21 H15 A1,1 0 0 1 14,20 V15 A1,1 0 0 1 15,14 Z"/>
                  </Canvas>
                </Viewbox>
              </Button>
            </StackPanel>
          </Border>
          <Border Padding="1" CornerRadius="8" Background="#0bffffff"
                  BorderBrush="#0fffffff" BorderThickness="1"
                  Margin="2,0"
                  IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=left}">
            <StackPanel Orientation="Vertical" Spacing="1">
              <Button Classes="view-btn" Width="22" Height="22"
                      Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=orbit}"
                      Command="{Binding SetViewModeCommand}"
                      CommandParameter="orbit"
                      ToolTip.Tip="Orbit view">
                <Viewbox Width="10" Height="10">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          Fill="Transparent"
                          Data="M15,12 A3,3 0 1 1 9,12 A3,3 0 1 1 15,12 M21,12 A9,9 0 1 1 3,12 A9,9 0 1 1 21,12"/>
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="view-btn" Width="22" Height="22"
                      Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}"
                      Command="{Binding SetViewModeCommand}"
                      CommandParameter="cards"
                      ToolTip.Tip="Card view">
                <Viewbox Width="10" Height="10">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          Fill="Transparent"
                          Data="M4,3 H9 A1,1 0 0 1 10,4 V9 A1,1 0 0 1 9,10 H4 A1,1 0 0 1 3,9 V4 A1,1 0 0 1 4,3 Z M15,3 H20 A1,1 0 0 1 21,4 V9 A1,1 0 0 1 20,10 H15 A1,1 0 0 1 14,9 V4 A1,1 0 0 1 15,3 Z M4,14 H9 A1,1 0 0 1 10,15 V20 A1,1 0 0 1 9,21 H4 A1,1 0 0 1 3,20 V15 A1,1 0 0 1 4,14 Z M15,14 H20 A1,1 0 0 1 21,15 V20 A1,1 0 0 1 20,21 H15 A1,1 0 0 1 14,20 V15 A1,1 0 0 1 15,14 Z"/>
                  </Canvas>
                </Viewbox>
              </Button>
            </StackPanel>
          </Border>
          <Border Padding="1" CornerRadius="8" Background="#0bffffff"
                  BorderBrush="#0fffffff" BorderThickness="1"
                  Margin="2,0"
                  IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=right}">
            <StackPanel Orientation="Vertical" Spacing="1">
              <Button Classes="view-btn" Width="22" Height="22"
                      Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=orbit}"
                      Command="{Binding SetViewModeCommand}"
                      CommandParameter="orbit"
                      ToolTip.Tip="Orbit view">
                <Viewbox Width="10" Height="10">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          Fill="Transparent"
                          Data="M15,12 A3,3 0 1 1 9,12 A3,3 0 1 1 15,12 M21,12 A9,9 0 1 1 3,12 A9,9 0 1 1 21,12"/>
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="view-btn" Width="22" Height="22"
                      Classes.active="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}"
                      Command="{Binding SetViewModeCommand}"
                      CommandParameter="cards"
                      ToolTip.Tip="Card view">
                <Viewbox Width="10" Height="10">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          Fill="Transparent"
                          Data="M4,3 H9 A1,1 0 0 1 10,4 V9 A1,1 0 0 1 9,10 H4 A1,1 0 0 1 3,9 V4 A1,1 0 0 1 4,3 Z M15,3 H20 A1,1 0 0 1 21,4 V9 A1,1 0 0 1 20,10 H15 A1,1 0 0 1 14,9 V4 A1,1 0 0 1 15,3 Z M4,14 H9 A1,1 0 0 1 10,15 V20 A1,1 0 0 1 9,21 H4 A1,1 0 0 1 3,20 V15 A1,1 0 0 1 4,14 Z M15,14 H20 A1,1 0 0 1 21,15 V20 A1,1 0 0 1 20,21 H15 A1,1 0 0 1 14,20 V15 A1,1 0 0 1 15,14 Z"/>
                  </Canvas>
                </Viewbox>
              </Button>
            </StackPanel>
          </Border>
        </Panel>

        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=top}"/>
        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=bottom}"/>
        <Border Width="16" Height="1" Background="#0fffffff" Margin="0,4"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=left}"/>
        <Border Width="16" Height="1" Background="#0fffffff" Margin="0,4"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=right}"/>

        <!-- Theme picker (App.tsx 1034-1091) â€” dots + custom accent input -->
        <Button Classes="theme-picker-btn" ToolTip.Tip="Theme">
          <StackPanel Orientation="{Binding ToolbarOrientation}" Spacing="5" VerticalAlignment="Center">
            <Ellipse Width="14" Height="14" Fill="{DynamicResource ThemeAccent}"/>
            <Path Width="8" Height="8" VerticalAlignment="Center" Stretch="Uniform"
                  Stroke="{DynamicResource ThemeText3}"
                  StrokeThickness="1.5"
                  StrokeLineCap="Round"
                  Fill="Transparent"
                  Data="M1,2 L4,5 L7,2"/>
          </StackPanel>
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <Border Background="{DynamicResource ThemeSurface}"
                      BorderBrush="#0fffffff" BorderThickness="1"
                      CornerRadius="12" Padding="10">
                <StackPanel Spacing="6" Width="140">
                  <ItemsControl ItemsSource="{Binding ThemeSwatches}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ThemeSwatchViewModel">
                        <Button Width="22" Height="22" Margin="3"
                                Background="{Binding AccentBrush}"
                                BorderBrush="{Binding BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="11"
                                ToolTip.Tip="{Binding Label}"
                                Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).SetThemeCommand}"
                                CommandParameter="{Binding Id}"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Border Height="1" Background="#14ffffff"/>
                  <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBox Grid.Column="0" Text="{Binding AccentColor}"
                             Watermark="#d4a853"
                             Background="#0affffff" BorderBrush="#18ffffff"
                             Foreground="{DynamicResource ThemeText}"
                             CornerRadius="5" Padding="6,3" FontSize="10"/>
                    <TextBlock Grid.Column="1" Text="Accent" FontSize="9"
                               Margin="6,0,0,0" Foreground="#50b0aaa0"
                               VerticalAlignment="Center"/>
                  </Grid>
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- Toolbar position â€” current glyph matches Vite layoutOptions (App.tsx 1094â€“1101) -->
        <Button Classes="theme-picker-btn" ToolTip.Tip="Toolbar position">
          <StackPanel Orientation="{Binding ToolbarOrientation}" Spacing="5" VerticalAlignment="Center">
            <Panel Width="14" Height="14">
              <!-- top -->
              <Viewbox Width="14" Height="14"
                       IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=top}">
                <Canvas Width="12" Height="12">
                  <Path Stroke="{DynamicResource ThemeText2}" StrokeThickness="1.2" Fill="Transparent"
                        Data="M2.5,1 L9.5,1 A1.5,1.5 0 0 1 11,2.5 L11,9.5 A1.5,1.5 0 0 1 9.5,11 L2.5,11 A1.5,1.5 0 0 1 1,9.5 L1,2.5 A1.5,1.5 0 0 1 2.5,1 Z"/>
                  <Path Fill="{DynamicResource ThemeText2}"
                        Data="M2,1 H10 A1,1 0 0 1 11,2 L11,4.5 L1,4.5 L1,2 A1,1 0 0 1 2,1 Z"/>
                </Canvas>
              </Viewbox>
              <!-- bottom -->
              <Viewbox Width="14" Height="14"
                       IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=bottom}">
                <Canvas Width="12" Height="12">
                  <Path Stroke="{DynamicResource ThemeText2}" StrokeThickness="1.2" Fill="Transparent"
                        Data="M2.5,1 L9.5,1 A1.5,1.5 0 0 1 11,2.5 L11,9.5 A1.5,1.5 0 0 1 9.5,11 L2.5,11 A1.5,1.5 0 0 1 1,9.5 L1,2.5 A1.5,1.5 0 0 1 2.5,1 Z"/>
                  <Path Fill="{DynamicResource ThemeText2}"
                        Data="M2,7.5 H10 A1,1 0 0 1 11,8.5 V10 A1,1 0 0 1 10,11 H2 A1,1 0 0 1 1,10 V8.5 A1,1 0 0 1 2,7.5 Z"/>
                </Canvas>
              </Viewbox>
              <!-- left -->
              <Viewbox Width="14" Height="14"
                       IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=left}">
                <Canvas Width="12" Height="12">
                  <Path Stroke="{DynamicResource ThemeText2}" StrokeThickness="1.2" Fill="Transparent"
                        Data="M2.5,1 L9.5,1 A1.5,1.5 0 0 1 11,2.5 L11,9.5 A1.5,1.5 0 0 1 9.5,11 L2.5,11 A1.5,1.5 0 0 1 1,9.5 L1,2.5 A1.5,1.5 0 0 1 2.5,1 Z"/>
                  <Path Fill="{DynamicResource ThemeText2}"
                        Data="M2,1 H3.5 A1,1 0 0 1 4.5,2 V10 A1,1 0 0 1 3.5,11 H2 A1,1 0 0 1 1,10 V2 A1,1 0 0 1 2,1 Z"/>
                </Canvas>
              </Viewbox>
              <!-- right -->
              <Viewbox Width="14" Height="14"
                       IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=right}">
                <Canvas Width="12" Height="12">
                  <Path Stroke="{DynamicResource ThemeText2}" StrokeThickness="1.2" Fill="Transparent"
                        Data="M2.5,1 L9.5,1 A1.5,1.5 0 0 1 11,2.5 L11,9.5 A1.5,1.5 0 0 1 9.5,11 L2.5,11 A1.5,1.5 0 0 1 1,9.5 L1,2.5 A1.5,1.5 0 0 1 2.5,1 Z"/>
                  <Path Fill="{DynamicResource ThemeText2}"
                        Data="M8.5,1 H10 A1,1 0 0 1 11,2 V10 A1,1 0 0 1 10,11 H8.5 A1,1 0 0 1 7.5,10 V2 A1,1 0 0 1 8.5,1 Z"/>
                </Canvas>
              </Viewbox>
            </Panel>
            <Path Width="8" Height="8" VerticalAlignment="Center" Stretch="Uniform"
                  Stroke="{DynamicResource ThemeText3}"
                  StrokeThickness="1.5"
                  StrokeLineCap="Round"
                  Fill="Transparent"
                  Data="M1,2 L4,5 L7,2"/>
          </StackPanel>
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <Border Background="{DynamicResource ThemeSurface}"
                      BorderBrush="#0fffffff" BorderThickness="1"
                      CornerRadius="10" Padding="6">
                <StackPanel Orientation="{Binding ToolbarOrientation}" Spacing="4">
                  <Button Classes="nav-btn" ToolTip.Tip="Top"
                          Command="{Binding SetToolbarPositionCommand}" CommandParameter="top">
                    <Viewbox Width="12" Height="12">
                      <Canvas Width="12" Height="12">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" Fill="Transparent"
                              Data="M2.5,1 L9.5,1 A1.5,1.5 0 0 1 11,2.5 L11,9.5 A1.5,1.5 0 0 1 9.5,11 L2.5,11 A1.5,1.5 0 0 1 1,9.5 L1,2.5 A1.5,1.5 0 0 1 2.5,1 Z"/>
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M2,1 H10 A1,1 0 0 1 11,2 L11,4.5 L1,4.5 L1,2 A1,1 0 0 1 2,1 Z"/>
                      </Canvas>
                    </Viewbox>
                  </Button>
                  <Button Classes="nav-btn" ToolTip.Tip="Bottom"
                          Command="{Binding SetToolbarPositionCommand}" CommandParameter="bottom">
                    <Viewbox Width="12" Height="12">
                      <Canvas Width="12" Height="12">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" Fill="Transparent"
                              Data="M2.5,1 L9.5,1 A1.5,1.5 0 0 1 11,2.5 L11,9.5 A1.5,1.5 0 0 1 9.5,11 L2.5,11 A1.5,1.5 0 0 1 1,9.5 L1,2.5 A1.5,1.5 0 0 1 2.5,1 Z"/>
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M2,7.5 H10 A1,1 0 0 1 11,8.5 V10 A1,1 0 0 1 10,11 H2 A1,1 0 0 1 1,10 V8.5 A1,1 0 0 1 2,7.5 Z"/>
                      </Canvas>
                    </Viewbox>
                  </Button>
                  <Button Classes="nav-btn" ToolTip.Tip="Left"
                          Command="{Binding SetToolbarPositionCommand}" CommandParameter="left">
                    <Viewbox Width="12" Height="12">
                      <Canvas Width="12" Height="12">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" Fill="Transparent"
                              Data="M2.5,1 L9.5,1 A1.5,1.5 0 0 1 11,2.5 L11,9.5 A1.5,1.5 0 0 1 9.5,11 L2.5,11 A1.5,1.5 0 0 1 1,9.5 L1,2.5 A1.5,1.5 0 0 1 2.5,1 Z"/>
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M2,1 H3.5 A1,1 0 0 1 4.5,2 V10 A1,1 0 0 1 3.5,11 H2 A1,1 0 0 1 1,10 V2 A1,1 0 0 1 2,1 Z"/>
                      </Canvas>
                    </Viewbox>
                  </Button>
                  <Button Classes="nav-btn" ToolTip.Tip="Right"
                          Command="{Binding SetToolbarPositionCommand}" CommandParameter="right">
                    <Viewbox Width="12" Height="12">
                      <Canvas Width="12" Height="12">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" Fill="Transparent"
                              Data="M2.5,1 L9.5,1 A1.5,1.5 0 0 1 11,2.5 L11,9.5 A1.5,1.5 0 0 1 9.5,11 L2.5,11 A1.5,1.5 0 0 1 1,9.5 L1,2.5 A1.5,1.5 0 0 1 2.5,1 Z"/>
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M8.5,1 H10 A1,1 0 0 1 11,2 V10 A1,1 0 0 1 10,11 H8.5 A1,1 0 0 1 7.5,10 V2 A1,1 0 0 1 8.5,1 Z"/>
                      </Canvas>
                    </Viewbox>
                  </Button>
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=top}"/>
        <Border Width="1" Height="16" Background="#0fffffff" Margin="4,0"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=bottom}"/>
        <Border Width="16" Height="1" Background="#0fffffff" Margin="0,4"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=left}"/>
        <Border Width="16" Height="1" Background="#0fffffff" Margin="0,4"
                IsVisible="{Binding ToolbarPosition, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=right}"/>

        <!-- Trailing nav-actions â€” index.css .nav-actions margin-left 6px, gap 1px -->
        <StackPanel Orientation="{Binding ToolbarOrientation}" Spacing="1" Margin="0" VerticalAlignment="Center">
          <Button Classes="nav-btn" ToolTip.Tip="Add game"
                  Command="{Binding ShowAddGameCommand}">
            <Viewbox Width="14" Height="14">
              <Canvas Width="24" Height="24">
                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="2"
                      StrokeLineCap="Round"
                      Fill="Transparent"
                      Data="M12,5 V19 M5,12 H19"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Button Classes="nav-btn" ToolTip.Tip="Settings (Ctrl+,)"
                  Command="{Binding OpenSettingsCommand}">
            <PathIcon Width="14" Height="14"
                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M12,15.5 A3.5,3.5 0 1 0 12,8.5 A3.5,3.5 0 1 0 12,15.5 M19.43,12.98 C19.47,12.66 19.5,12.34 19.5,12 C19.5,11.66 19.47,11.34 19.43,11.02 L21.54,9.37 C21.73,9.22 21.78,8.95 21.66,8.73 L19.66,5.27 C19.54,5.05 19.27,4.97 19.05,5.05 L16.56,6.05 C16.04,5.65 15.5,5.32 14.87,5.07 L14.5,2.42 C14.46,2.18 14.25,2 14,2 H10 C9.75,2 9.54,2.18 9.5,2.42 L9.13,5.07 C8.5,5.32 7.96,5.65 7.44,6.05 L4.95,5.05 C4.73,4.97 4.46,5.05 4.34,5.27 L2.34,8.73 C2.22,8.95 2.27,9.22 2.46,9.37 L4.57,11.02 C4.53,11.34 4.5,11.66 4.5,12 C4.5,12.34 4.53,12.66 4.57,12.98 L2.46,14.63 C2.27,14.78 2.22,15.05 2.34,15.27 L4.34,18.73 C4.46,18.95 4.73,19.03 4.95,18.95 L7.44,17.95 C7.96,18.35 8.5,18.68 9.13,18.93 L9.5,21.58 C9.54,21.82 9.75,22 10,22 H14 C14.25,22 14.46,21.82 14.5,21.58 L14.87,18.93 C15.5,18.68 16.04,18.35 16.56,17.95 L19.05,18.95 C19.27,19.03 19.54,18.95 19.66,18.73 L21.66,15.27 C21.78,15.05 21.73,14.78 21.54,14.63 L19.43,12.98 Z"/>
          </Button>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
         Stream pill (App.tsx 922-935) â€” floats bottom-right only
         in cards mode and only offers the two streamable platforms.
         Remote Play opens the Chiaki panel; Cloud Gaming opens the
         xCloud panel. Detect / Connect live in the empty state and
         Settings panel respectively; they deliberately do NOT have
         a dedicated nav-pill button in the Electron original.
    â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
            Margin="0,0,16,16"
            CornerRadius="22" Padding="6,4"
            Background="{DynamicResource ThemeSurface}"
            BorderBrush="#17ffffff" BorderThickness="1"
            BoxShadow="0 8 32 0 #b3000000, 0 2 8 0 #80000000, inset 0 2 0 0 #0dffffff"
            ZIndex="50"
            RenderTransformOrigin="0.5,0.5"
            IsVisible="{Binding ViewMode, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}, ConverterParameter=cards}">
      <Border.RenderTransform>
        <ScaleTransform ScaleX="{Binding ToolbarScale}" ScaleY="{Binding ToolbarScale}"/>
      </Border.RenderTransform>
      <StackPanel Orientation="Horizontal" Spacing="2">
        <Button Classes="stream-pill-btn" ToolTip.Tip="PlayStation Remote Play"
                Command="{Binding OpenChiakiCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Width="22" Height="22" CornerRadius="11"
                    Background="#33003087"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
              <PathIcon Width="14" Height="14" Foreground="#4d8fff"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Data="M8.984,2.596 V20.143 L12.899,21.404 V6.688 C12.899,5.998 13.203,5.537 13.693,5.697 C14.329,5.877 14.453,6.511 14.453,7.202 V13.077 C16.894,14.27 18.815,13.075 18.815,9.925 C18.815,6.688 17.689,5.25 14.377,4.098 C13.07,3.65 10.649,2.912 8.987,2.596 Z"/>
            </Border>
            <TextBlock Text="Remote Play" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Classes="stream-pill-btn" ToolTip.Tip="Xbox Cloud Gaming"
                Command="{Binding OpenXcloudCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Width="22" Height="22" CornerRadius="11"
                    Background="#33107c10"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
              <PathIcon Width="12" Height="12" Foreground="#34d399"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Data="M4.102,21.033 A11.95,11.95 0 0 0 12,24 A11.96,11.96 0 0 0 19.902,21.033 C21.779,19.121 15.586,12.324 12,9.616 C8.418,12.324 2.221,19.121 4.102,21.033 Z"/>
            </Border>
            <TextBlock Text="Cloud Gaming" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- â”€â”€ Status bar (cover download progress) â”€â”€ -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
            Margin="0,0,0,20"
            CornerRadius="20" Padding="14,6"
            Background="{DynamicResource ThemeSurface}"
            IsVisible="{Binding StatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
      <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
    </Border>

    <!-- â”€â”€ Subtle progress pill (bottom-right) â€” mirrors Electron's subtle-pill â”€â”€ -->
    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
            Margin="0,0,20,20" CornerRadius="14" Padding="12,8"
            Background="#ec06071e" BorderBrush="#18ffffff" BorderThickness="1"
            MinWidth="220"
            BoxShadow="0 8 24 0 #80000000"
            IsVisible="{Binding ShowProgressPill}">
      <StackPanel Spacing="6">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <!-- Check (done) / spinner (in progress) -->
          <Border Width="14" Height="14" CornerRadius="7"
                  Background="{DynamicResource ThemeAccent}"
                  IsVisible="{Binding ProgressPillDone}">
            <TextBlock Text="âœ“" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeOnAccent}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <Canvas Width="14" Height="14"
                  RenderTransformOrigin="0.5,0.5"
                  IsVisible="{Binding !ProgressPillDone}">
            <Ellipse Width="11" Height="11" Canvas.Left="1.5" Canvas.Top="1.5"
                     Stroke="{DynamicResource ThemeFocusRingColor}" StrokeThickness="2" Fill="Transparent"/>
            <Path Stroke="{DynamicResource ThemeAccent}" StrokeThickness="2"
                  StrokeLineCap="Round" Fill="Transparent"
                  Data="M 7,1.5 A 5.5,5.5 0 1 1 1.5,7"/>
          </Canvas>

          <TextBlock Text="{Binding ProgressPillText}" FontSize="11"
                     Foreground="{DynamicResource ThemeText2}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <ProgressBar Minimum="0" Maximum="1" Height="3"
                     Value="{Binding ProgressPillPercent}"
                     Background="#14ffffff"
                     Foreground="{DynamicResource ThemeAccent}"
                     CornerRadius="2"
                     IsVisible="{Binding !ProgressPillDone}"/>
      </StackPanel>
    </Border>

  </Panel>

</UserControl>

