<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:orbit="clr-namespace:Cereal.App.Controls.Orbit"
             x:Class="Cereal.App.Views.OrbitView">

  <Grid>
    <!-- Fullscreen parallax star layers behind the world. -->
    <orbit:ParallaxStarBackground x:Name="Parallax"/>

    <!-- Native Avalonia orbit (pan/zoom host). Content is added in code-behind. -->
    <orbit:OrbitWorld x:Name="World"/>

    <!-- Fallback error overlay (kept for parity with the old view) -->
    <Border x:Name="ErrorOverlay" Background="#0d0d22" IsVisible="False">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <TextBlock x:Name="ErrorText"
                   FontSize="14" Foreground="#cc6666"
                   HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"/>
      </StackPanel>
    </Border>
  </Grid>

</UserControl>
