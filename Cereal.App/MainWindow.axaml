<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cereal.App.ViewModels"
        xmlns:views="using:Cereal.App.Views"
        xmlns:panels="using:Cereal.App.Views.Panels"
        xmlns:conv="using:Cereal.App"
        x:Class="Cereal.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Cereal"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        Classes.no-motion="{Binding UiAnimationsDisabled}"
        Background="{DynamicResource ThemeVoid}">

  <Window.Styles>
    <Style Selector="Border.surface-fade">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
      <Setter Property="RenderTransform" Value="translateY(0px)"/>
    </Style>
    <Style Selector="Border.surface-fade:pointerover">
      <Setter Property="RenderTransform" Value="translateY(-1px)"/>
    </Style>
    <Style Selector="Window.no-motion Border.surface-fade">
      <Setter Property="Transitions">
        <Transitions/>
      </Setter>
      <Setter Property="RenderTransform" Value="translateY(0px)"/>
    </Style>
    <Style Selector="panels|FocusPanel">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window.no-motion panels|FocusPanel">
      <Setter Property="Transitions">
        <Transitions/>
      </Setter>
    </Style>

    <Style Selector="Button.win-ctrl">
      <Setter Property="Width" Value="46"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Foreground" Value="#66b0aaa0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.win-ctrl:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#0dffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>
    <Style Selector="Button.win-ctrl:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#18ffffff"/>
    </Style>
    <Style Selector="Button.win-ctrl.close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#c42b1c"/>
      <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.win-ctrl.close:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#a72216"/>
      <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.win-ctrl:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadowInset}"/>
    </Style>

    <!-- Tab strip: close affordance always visible; lift on row hover -->
    <Style Selector="Button.tab-close">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="22"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="Margin" Value="2,0,0,0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Foreground" Value="#6d706b63"/>
      <Setter Property="CornerRadius" Value="5"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Opacity" Value="0.55"/>
    </Style>
    <Style Selector="Button.tab-close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#22ffffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>
    <Style Selector="Button.tab-close:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#30ffffff"/>
    </Style>
    <Style Selector="Button.tab-close:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadowInset}"/>
    </Style>
    <Style Selector="Button.title-tab:pointerover Button.tab-close">
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="Button.title-tab">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,2,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="{DynamicResource ThemeText3}"/>
    </Style>
    <Style Selector="Button.title-tab /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="Button.title-tab:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#0affffff"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText2}"/>
    </Style>
    <Style Selector="Button.title-tab.active /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeText}"/>
    </Style>
    <Style Selector="Button.title-tab:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#12ffffff"/>
    </Style>
    <Style Selector="Button.title-tab:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadowInset}"/>
    </Style>

    <!-- index.css .search-esc -->
    <Style Selector="Button.search-esc">
      <Setter Property="Padding" Value="6,14"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="#0fffffff"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Foreground" Value="#706b63"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.search-esc:pointerover /template/ ContentPresenter">
      <Setter Property="BorderBrush" Value="#706b63"/>
      <Setter Property="TextElement.Foreground" Value="#b0aaa0"/>
    </Style>
    <Style Selector="Button.search-esc:focus-visible /template/ ContentPresenter">
      <Setter Property="BoxShadow" Value="{DynamicResource ThemeFocusRingBoxShadow}"/>
    </Style>

    <!-- index.css .search-plat-chip (active colors come from MultiBinding) -->
    <Style Selector="Button.search-plat-chip">
      <Setter Property="Padding" Value="2,8"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.search-plat-chip:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#0bffffff"/>
    </Style>

    <!-- ── Panel backdrop fade (#1 partial) ── -->
    <Style Selector="Border.panel-backdrop">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.22"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.panel-backdrop.open">
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Window.no-motion Border.panel-backdrop">
      <Setter Property="Transitions"><Transitions/></Setter>
    </Style>

    <!-- ── Side panel slide-in: 560px panels (#2) ── -->
    <Style Selector="panels|SettingsPanel, panels|ChiakiPanel, panels|PlatformsPanel, panels|PlatformAuthPanel">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="RenderTransform" Value="translateX(700px)"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="panels|SettingsPanel.open, panels|ChiakiPanel.open, panels|PlatformsPanel.open, panels|PlatformAuthPanel.open">
      <Setter Property="Opacity" Value="1"/>
      <Setter Property="RenderTransform" Value="translateX(0px)"/>
    </Style>

    <!-- ── Side panel slide-in: 480px panels (#2) ── -->
    <Style Selector="panels|DetectPanel">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="RenderTransform" Value="translateX(500px)"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="panels|DetectPanel.open">
      <Setter Property="Opacity" Value="1"/>
      <Setter Property="RenderTransform" Value="translateX(0px)"/>
    </Style>

    <!-- no-motion overrides for side panels -->
    <Style Selector="Window.no-motion panels|SettingsPanel">
      <Setter Property="Transitions"><Transitions/></Setter>
    </Style>
    <Style Selector="Window.no-motion panels|ChiakiPanel">
      <Setter Property="Transitions"><Transitions/></Setter>
    </Style>
    <Style Selector="Window.no-motion panels|PlatformsPanel">
      <Setter Property="Transitions"><Transitions/></Setter>
    </Style>
    <Style Selector="Window.no-motion panels|PlatformAuthPanel">
      <Setter Property="Transitions"><Transitions/></Setter>
    </Style>
    <Style Selector="Window.no-motion panels|DetectPanel">
      <Setter Property="Transitions"><Transitions/></Setter>
    </Style>

    <!-- ── Continue banner slide-up (#4) ── -->
    <Style Selector="Border.continue-banner">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="RenderTransform" Value="translateY(20px)"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.32" Easing="CubicEaseOut"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.32" Easing="CubicEaseOut"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.continue-banner.shown">
      <Setter Property="Opacity" Value="1"/>
      <Setter Property="RenderTransform" Value="translateY(0px)"/>
    </Style>
    <Style Selector="Window.no-motion Border.continue-banner">
      <Setter Property="Transitions"><Transitions/></Setter>
    </Style>

    <!-- ── Search overlay fade-in (#8) ── -->
    <Style Selector="Panel.search-overlay">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Panel.search-overlay.open">
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Window.no-motion Panel.search-overlay">
      <Setter Property="Transitions"><Transitions/></Setter>
    </Style>
  </Window.Styles>

  <LayoutTransformControl x:Name="RootScaler">
  <Grid x:Name="RootGrid" RowDefinitions="36,*">

    <!-- Title bar — same base as content (ThemeVoid); no seam line into main app -->
    <Border Grid.Row="0"
            PointerPressed="TitleBar_PointerPressed"
            Background="{DynamicResource ThemeVoid}">
      <Grid ColumnDefinitions="Auto,*,Auto">

        <!-- Launcher / library -->
        <Button Grid.Column="0"
                Classes="title-tab"
                Classes.active="{Binding IsLibraryTabActive}"
                Command="{Binding OpenLauncherTabCommand}"
                Margin="8,0,0,0"
                VerticalAlignment="Stretch">
          <DockPanel>
            <Rectangle DockPanel.Dock="Bottom" Height="2" Margin="10,0" RadiusX="1" RadiusY="1"
                       Fill="{DynamicResource ThemeAccent}"
                       IsVisible="{Binding IsLibraryTabActive}"/>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="10,0">
              <Panel Width="14" Height="14" VerticalAlignment="Center">
                <Ellipse Width="13" Height="13" Stroke="{DynamicResource ThemeAccent}" StrokeThickness="1.2"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Ellipse Width="2.4" Height="2.4" Fill="{DynamicResource ThemeAccentSoft}"
                         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="3,3,0,0"/>
                <Ellipse Width="2.4" Height="2.4" Fill="{DynamicResource ThemeAccent}"
                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,3,2,0"/>
                <Ellipse Width="2" Height="2" Fill="{DynamicResource ThemeAccentSoft}"
                         HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
              </Panel>
              <StackPanel Spacing="1" VerticalAlignment="Center">
                <TextBlock Text="Cereal" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Text="Library" FontSize="9" Foreground="{DynamicResource ThemeText4}"/>
              </StackPanel>
            </StackPanel>
          </DockPanel>
        </Button>

        <!-- Panel + stream tabs -->
        <StackPanel Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Left" VerticalAlignment="Stretch"
                    Margin="4,0,6,0">
          <ItemsControl ItemsSource="{Binding PanelTabs}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:PanelTabViewModel">
                <Button Classes="title-tab"
                        Classes.active="{Binding IsActive}"
                        Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SwitchToPanelTabCommand}"
                        CommandParameter="{Binding Id}"
                        VerticalAlignment="Stretch">
                  <DockPanel MinWidth="92" MaxWidth="210">
                    <Rectangle DockPanel.Dock="Bottom" Height="2" Margin="8,0" RadiusX="1" RadiusY="1"
                               Fill="{DynamicResource ThemeAccent}"
                               IsVisible="{Binding IsActive}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0,6,0">
                      <TextBlock Text="{Binding Title}"
                                 FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                 MaxWidth="148" TextTrimming="CharacterEllipsis"/>
                      <Button Classes="tab-close"
                              ToolTip.Tip="Close tab"
                              Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).ClosePanelTabCommand}"
                              CommandParameter="{Binding Id}">
                        <PathIcon Width="7" Height="7"
                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M1,1 L7,7 M7,1 L1,7"/>
                      </Button>
                    </StackPanel>
                  </DockPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Border Width="1" Height="18" Margin="6,0,8,0" Background="#12ffffff"
                  CornerRadius="1" VerticalAlignment="Center"
                  IsVisible="{Binding ShowTabGroupSeparator}"/>

          <ItemsControl ItemsSource="{Binding StreamTabs}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:StreamTabViewModel">
                <Button Classes="title-tab"
                        Classes.active="{Binding IsSessionLive}"
                        Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SwitchToStreamTabCommand}"
                        CommandParameter="{Binding}"
                        VerticalAlignment="Stretch">
                  <DockPanel MinWidth="96" MaxWidth="240">
                    <Rectangle DockPanel.Dock="Bottom" Height="2" Margin="8,0" RadiusX="1" RadiusY="1"
                               Fill="{Binding StreamAccentColor, Converter={x:Static vm:ColorStringToBrushConverter.Instance}}"
                               IsVisible="{Binding IsSessionLive}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0,6,0">
                      <StackPanel Spacing="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayTitle}"
                                   FontSize="11" FontWeight="SemiBold"
                                   MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding State}"
                                   FontSize="9" Foreground="{DynamicResource ThemeText4}" Margin="0,1,0,0"/>
                      </StackPanel>
                      <Button Classes="tab-close"
                              ToolTip.Tip="Close tab"
                              Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).CloseStreamTabCommand}"
                              CommandParameter="{Binding GameId}">
                        <PathIcon Width="7" Height="7"
                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M1,1 L7,7 M7,1 L1,7"/>
                      </Button>
                    </StackPanel>
                  </DockPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Right: Vite parity window controls -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
          <Button Classes="win-ctrl" Click="WindowMinimize_Click" ToolTip.Tip="Minimize">
            <PathIcon Width="10" Height="10" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M0,0 L10,0"/>
          </Button>
          <Button Classes="win-ctrl" Click="WindowMaximize_Click" ToolTip.Tip="Maximize">
            <Border Width="10" Height="10"
                    BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    BorderThickness="1"/>
          </Button>
          <Button Classes="win-ctrl close" Click="WindowClose_Click" ToolTip.Tip="Close">
            <PathIcon Width="10" Height="10" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M0,0 L10,10 M10,0 L0,10"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Content: main view + overlay panels ── -->
    <Panel Grid.Row="1">

      <!-- Main library view (always visible) -->
      <views:MainView x:Name="MainViewContent"/>

      <!-- Chiaki video embed target rect (Windows) — stream reparented into main window client area -->
      <Border x:Name="ChiakiStreamHost"
              ZIndex="8"
              IsVisible="{Binding ShowChiakiEmbedHost}"
              Background="Transparent"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"/>

      <!-- Overlay backdrop (blocks clicks, dims background) -->
      <!-- index.css .panel-backdrop — rgba(0,0,0,0.55) -->
      <Border Classes="panel-backdrop"
              Classes.open="{Binding AnyPanelOpen}"
              Background="#8c000000"
              IsHitTestVisible="{Binding AnyPanelOpen}"
              PointerPressed="Backdrop_PointerPressed"/>

      <!-- Side widths: index.css .side-panel 480px, .side-panel.wide 560px -->
      <panels:SettingsPanel HorizontalAlignment="Right"
                            Width="680"
                            IsHitTestVisible="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsSettingsPanelVisible}"
                            Classes.open="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsSettingsPanelVisible}"/>

      <panels:DetectPanel HorizontalAlignment="Right"
                          Width="480"
                          IsHitTestVisible="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsDetectPanelVisible}"
                          Classes.open="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsDetectPanelVisible}"/>

      <panels:ChiakiPanel HorizontalAlignment="Right"
                          Width="560"
                          IsHitTestVisible="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsChiakiPanelVisible}"
                          Classes.open="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsChiakiPanelVisible}"/>

      <panels:PlatformsPanel HorizontalAlignment="Right"
                             Width="560"
                             IsHitTestVisible="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsPlatformsPanelVisible}"
                             Classes.open="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsPlatformsPanelVisible}"/>

      <panels:PlatformAuthPanel HorizontalAlignment="Right"
                                Width="560"
                                ZIndex="2"
                                DataContext="{Binding $parent[Window].((vm:MainViewModel)DataContext)}"
                                IsHitTestVisible="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsPlatformAuthPanelVisible}"
                                Classes.open="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsPlatformAuthPanelVisible}"/>

      <!-- Focus panel — full screen game detail (topmost) -->
      <panels:FocusPanel IsVisible="True"
                         IsHitTestVisible="{Binding ShowFocus}"
                         Opacity="{Binding ShowFocus, Converter={x:Static conv:BoolConverters.ToObject},
                                  ConverterParameter='1,0'}"/>

      <!-- ── Stream overlay bar ── -->
      <Border x:Name="StreamBarBorder"
              VerticalAlignment="{Binding ToolbarVerticalAlignment}"
              IsVisible="{Binding ShowStreamBar}"
              Classes="surface-fade"
              Background="#d206071e"
              BorderBrush="#17ffffff"
              BorderThickness="{Binding StreamBarBorderThickness}"
              BoxShadow="0 8 32 0 #b3000000, 0 2 8 0 #80000000, inset 0 2 0 0 #0dffffff"
              ZIndex="60"
              PointerEntered="StreamBar_PointerEntered"
              PointerExited="StreamBar_PointerExited">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="16,0" Height="38">
          <!-- Dot + title -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center">
            <Ellipse Width="7" Height="7" VerticalAlignment="Center">
              <Ellipse.Fill>
                <SolidColorBrush Color="#22c55e"/>
              </Ellipse.Fill>
            </Ellipse>
            <TextBlock Text="{Binding ActiveStreamTab.DisplayTitle}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center"/>
          </StackPanel>
          <!-- Platform label -->
          <Border Grid.Column="1" CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                  Background="#18ffffff" VerticalAlignment="Center">
            <TextBlock Text="{Binding ActiveStreamTab.PlatformLabel}"
                       FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeText2}"/>
          </Border>
          <!-- Quality stats (PSN Remote Play) -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14"
                      VerticalAlignment="Center" Margin="14,0"
                      IsVisible="{Binding ActiveStreamTab.HasQualityStats}">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBlock Text="{Binding ActiveStreamTab.BitrateLabel}"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center"/>
              <TextBlock Text="Mbps" FontSize="9" Foreground="{DynamicResource ThemeText3}"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBlock Text="{Binding ActiveStreamTab.FpsLabel}"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center"/>
              <TextBlock Text="FPS" FontSize="9" Foreground="{DynamicResource ThemeText3}"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBlock Text="{Binding ActiveStreamTab.LatencyLabel}"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center"/>
              <TextBlock Text="ms" FontSize="9" Foreground="{DynamicResource ThemeText3}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
          <!-- State label (hidden when showing quality stats) -->
          <TextBlock Grid.Column="2" Text="{Binding ActiveStreamTab.State}"
                     FontSize="11" Foreground="{DynamicResource ThemeText3}"
                     VerticalAlignment="Center" Margin="14,0"
                     IsVisible="{Binding !ActiveStreamTab.HasQualityStats}"/>
          <!-- Minimize -->
          <Button Grid.Column="3"
                  Width="30" Height="30" Margin="4,0,0,0"
                  VerticalAlignment="Center"
                  Background="Transparent" Foreground="{DynamicResource ThemeText3}"
                  BorderThickness="0" CornerRadius="6" Padding="0"
                  FontSize="12" Cursor="Hand"
                  Click="Minimize_Click"
                  ToolTip.Tip="Minimize">
            <PathIcon Width="10" Height="10"
                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M0,5 L10,5"/>
          </Button>
          <!-- Fullscreen toggle -->
          <Button Grid.Column="4" x:Name="FullscreenBtn"
                  Width="30" Height="30" Margin="4,0,0,0"
                  VerticalAlignment="Center"
                  Background="Transparent" Foreground="{DynamicResource ThemeText3}"
                  BorderThickness="0" CornerRadius="6" Padding="0"
                  FontSize="12" Cursor="Hand"
                  Click="ToggleFullscreen_Click"
                  ToolTip.Tip="Toggle fullscreen">
            <PathIcon Width="12" Height="12"
                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M8,1 H11 V4 M4,11 H1 V8 M11,8 V11 H8 M1,4 V1 H4 M11,1 L7,5 M1,11 L5,7"/>
          </Button>
          <!-- Stop button -->
          <Button Grid.Column="5" Content="Stop" Margin="8,0,0,0"
                  VerticalAlignment="Center"
                  Background="#33ff4444" Foreground="#ff7070"
                  BorderThickness="0" CornerRadius="6" Padding="12,4"
                  FontSize="11" Cursor="Hand"
                  Command="{Binding CloseStreamTabCommand}"
                  CommandParameter="{Binding ActiveStreamTab.GameId}"/>
        </Grid>
      </Border>

      <!-- ── GUI session float (chiaki/xcloud launcher-open state) ── -->
      <Border IsVisible="{Binding ShowGuiStreamFloat}"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Margin="0,0,12,72"
              ZIndex="61"
              CornerRadius="10"
              Background="#de0f1118"
              BorderBrush="#22ffffff"
              BorderThickness="1"
              Padding="10,8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="GUI open" FontSize="11" Foreground="{DynamicResource ThemeText2}" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding GuiStreamTab.DisplayTitle}" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center" MaxWidth="180"
                     TextTrimming="CharacterEllipsis"/>
          <Button Content="Open" Classes="nav-btn" Padding="8,4"
                  Command="{Binding OpenGuiStreamCommand}"/>
          <Button Content="Stop" Classes="nav-btn" Padding="8,4"
                  Command="{Binding CloseStreamTabCommand}"
                  CommandParameter="{Binding GuiStreamTab.GameId}"/>
        </StackPanel>
      </Border>

      <!-- ── Stream connecting spinner ── -->
      <Panel IsVisible="{Binding IsStreamConnecting}"
             IsHitTestVisible="False"
             ZIndex="55">
        <Border Background="#cc02020c"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
          <Border Width="40" Height="40" CornerRadius="20"
                  BorderBrush="#1affffff" BorderThickness="2"
                  HorizontalAlignment="Center">
            <Border.RenderTransform>
              <RotateTransform/>
            </Border.RenderTransform>
            <Border.Transitions>
              <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.8"
                                               Easing="LinearEasing"/>
              </Transitions>
            </Border.Transitions>
          </Border>
          <TextBlock Text="{Binding ActiveStreamTab.State,
                           StringFormat='Connecting — {0}…'}"
                     FontSize="11" Foreground="{DynamicResource ThemeText3}"
                     LetterSpacing="1" HorizontalAlignment="Center"/>
        </StackPanel>
      </Panel>

      <!-- ── Continue banner (bottom-center, slide-up) ── -->
      <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
              Margin="0,0,0,60"
              IsHitTestVisible="{Binding ShowContinueBanner}"
              Classes="continue-banner"
              Classes.shown="{Binding ShowContinueBanner}"
              CornerRadius="12"
              Background="#e80b0d26"
              BorderBrush="#1affffff"
              BorderThickness="1"
              ZIndex="50">
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="10">
          <!-- Cover thumbnail -->
          <Border Width="44" Height="58" CornerRadius="6" ClipToBounds="True"
                  Background="{DynamicResource ThemeCardUp}" VerticalAlignment="Center">
            <Panel>
              <Image Source="{Binding ContinueGame.CoverPath}"
                     Stretch="UniformToFill"
                     IsVisible="{Binding ContinueGame.HasCover}"/>
              <TextBlock Text="{Binding ContinueGame.Initial}"
                         FontSize="20" FontWeight="Bold"
                         Foreground="{DynamicResource ThemeText}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding !ContinueGame.HasCover}"/>
            </Panel>
          </Border>
          <StackPanel Spacing="2" VerticalAlignment="Center">
            <TextBlock Text="CONTINUE" FontSize="8" FontWeight="Bold"
                       LetterSpacing="1.5" Foreground="#40b0aaa0"/>
            <TextBlock Text="{Binding ContinueGame.Name}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeText}" MaxWidth="220"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding ContinueGame.LastPlayedLabel}"
                       FontSize="10"
                       Foreground="#60b0aaa0"/>
          </StackPanel>
          <Button VerticalAlignment="Center"
                  Background="{DynamicResource ThemeAccentSoft}" Foreground="{DynamicResource ThemeAccent}"
                  FontSize="11" FontWeight="Bold"
                  CornerRadius="8" Padding="14,7" BorderThickness="1" BorderBrush="{DynamicResource ThemeFocusRingColor}" Cursor="Hand"
                  Command="{Binding LaunchGameCommand}"
                  CommandParameter="{Binding ContinueGame}">
            <Button.Styles>
              <Style Selector="Button:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeOnAccent}"/>
              </Style>
            </Button.Styles>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <PathIcon Width="12" Height="12"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Data="M8,6 V18 L18,12 Z"/>
              <TextBlock Text="Play" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button VerticalAlignment="Center"
                  Background="Transparent" Foreground="{DynamicResource ThemeText3}"
                  FontSize="16" Width="28" Height="28"
                  CornerRadius="14" Padding="0" BorderThickness="0" Cursor="Hand"
                  ToolTip.Tip="Dismiss"
                  Command="{Binding DismissContinueBannerCommand}">
            <PathIcon Width="10" Height="10"
                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M1,1 L9,9 M9,1 L1,9"/>
          </Button>
        </StackPanel>
      </Border>

      <!-- ── App auto-update banner (App.tsx 1274–1294).
           Lives just above the toast stack in the bottom-right. -->
      <Border IsVisible="{Binding ShowAppUpdate}"
              VerticalAlignment="Bottom" HorizontalAlignment="Right"
              Margin="0,0,20,84"
              Width="300"
              Classes="surface-fade"
              CornerRadius="12" Padding="12,10"
              Background="#f414141e"
              BorderBrush="#1affffff" BorderThickness="1"
              BoxShadow="0 8 32 0 #80000000"
              ZIndex="201">
        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
          <!-- Status dot -->
          <Border Grid.Column="0" Grid.RowSpan="2" Width="22" Height="22"
                  CornerRadius="11" Margin="0,0,10,0"
                  VerticalAlignment="Center">
            <Border.Background>
              <SolidColorBrush Color="{DynamicResource ThemeAccentColor}"/>
            </Border.Background>
            <TextBlock Text="↑" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeOnAccent}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <!-- Title: swaps between "Downloading update…" / "Update ready" -->
          <TextBlock Grid.Column="1" Grid.Row="0" FontSize="12" FontWeight="Bold"
                     Foreground="{DynamicResource ThemeText}"
                     Text="Downloading update…"
                     IsVisible="{Binding AppUpdateDownloading}"/>
          <TextBlock Grid.Column="1" Grid.Row="0" FontSize="12" FontWeight="Bold"
                     Foreground="{DynamicResource ThemeText}"
                     Text="Update ready"
                     IsVisible="{Binding AppUpdateReady}"/>
          <!-- Subtitle: version / "Restart to apply" -->
          <TextBlock Grid.Column="1" Grid.Row="1" FontSize="11"
                     Foreground="{DynamicResource ThemeText3}"
                     TextTrimming="CharacterEllipsis"
                     IsVisible="{Binding AppUpdateDownloading}"
                     Text="{Binding AppUpdateDownloadLabel}"/>
          <TextBlock Grid.Column="1" Grid.Row="1" FontSize="11"
                     Foreground="{DynamicResource ThemeText3}"
                     TextTrimming="CharacterEllipsis"
                     IsVisible="{Binding AppUpdateReady}">
            <Run Text="v"/>
            <Run Text="{Binding AppUpdateVersion}"/>
            <Run Text=" — Restart to apply"/>
          </TextBlock>
          <!-- Action: Restart when ready, else dismiss × -->
          <Button Grid.Column="2" Grid.RowSpan="2" Content="Restart"
                  IsVisible="{Binding AppUpdateReady}"
                  VerticalAlignment="Center"
                  Background="{DynamicResource ThemeAccent}"
                  Foreground="{DynamicResource ThemeOnAccent}"
                  FontWeight="Bold" FontSize="11"
                  CornerRadius="6" Padding="10,5"
                  BorderThickness="0" Cursor="Hand"
                  Command="{Binding InstallAppUpdateCommand}"/>
          <Button Grid.Column="2" Grid.RowSpan="2"
                  IsVisible="{Binding !AppUpdateReady}"
                  VerticalAlignment="Center"
                  Background="Transparent" Foreground="{DynamicResource ThemeText3}"
                  FontSize="11"
                  BorderThickness="0" Cursor="Hand"
                  ToolTip.Tip="Dismiss"
                  Command="{Binding DismissAppUpdateCommand}">
            <PathIcon Width="9" Height="9"
                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M1,1 L8,8 M8,1 L1,8"/>
          </Button>
        </Grid>
      </Border>

      <!-- App process stats (current Cereal usage) -->
      <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
              Margin="0,0,20,20"
              ZIndex="199"
              CornerRadius="8"
              Padding="10,6"
              Background="#cc0b0d26"
              BorderBrush="#1affffff"
              BorderThickness="1">
        <TextBlock Text="{Binding AppUsageLabel}"
                   FontSize="10"
                   Foreground="{DynamicResource ThemeText3}"/>
      </Border>

      <!-- ── Toast stack (bottom-center) ── -->
      <ItemsControl ItemsSource="{Binding Toasts}"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Margin="0,0,0,24"
                    ZIndex="200">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="8"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ToastViewModel">
            <Border CornerRadius="10" Padding="14,9"
                    Classes="surface-fade"
                    Background="#e80b0d26"
                    BorderBrush="#1affffff"
                    BorderThickness="1">
              <TextBlock Text="{Binding Message}"
                         FontSize="12" Foreground="{DynamicResource ThemeText2}"
                         MaxWidth="300" TextWrapping="Wrap"/>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- ── Media player (SMTC now-playing widget) — Electron MediaPlayer.tsx parity.
           Follows ToolbarPosition: opposite edge from the toolbar. -->
      <Border DataContext="{Binding Media}"
              VerticalAlignment="{Binding $parent[Window].((vm:MainViewModel)DataContext).MediaVerticalAlignment}"
              HorizontalAlignment="Left"
              Margin="{Binding $parent[Window].((vm:MainViewModel)DataContext).MediaWidgetMargin}"
              CornerRadius="22"
              Background="#d206071e"
              BorderBrush="#17ffffff" BorderThickness="1"
              BoxShadow="0 8 32 0 #b3000000, 0 2 8 0 #80000000, inset 0 2 0 0 #0dffffff"
              IsVisible="{Binding HasMedia}"
              ZIndex="55"
              RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
          <ScaleTransform ScaleX="{Binding $parent[Window].((vm:MainViewModel)DataContext).ToolbarScale}"
                          ScaleY="{Binding $parent[Window].((vm:MainViewModel)DataContext).ToolbarScale}"/>
        </Border.RenderTransform>
        <!-- Collapsed compact pill -->
        <Panel>
          <Border IsVisible="{Binding IsCollapsed}"
                  CornerRadius="22" Padding="10,8" Cursor="Hand"
                  PointerPressed="MediaCollapsedPill_Click">
            <PathIcon Width="14" Height="14"
                      Foreground="{DynamicResource ThemeAccent}"
                      Data="M14,3 V13.5 A3,3 0 1 1 12,10.66 V6.5 L20,4.5 V11.5 A3,3 0 1 1 18,8.66 V2 Z"/>
          </Border>

          <!-- Expanded player -->
          <Border IsVisible="{Binding !IsCollapsed}" Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
              <!-- Album art / note icon -->
              <Border Width="38" Height="38" CornerRadius="6" ClipToBounds="True"
                      Background="#14ffffff" Cursor="Hand"
                      PointerPressed="MediaArt_Click"
                      ToolTip.Tip="Collapse">
                <Panel>
                  <Image Source="{Binding AlbumArt}" Stretch="UniformToFill"
                         IsVisible="{Binding AlbumArt, Converter={x:Static conv:ObjectConverters.IsNotNull}}"/>
                  <PathIcon Width="16" Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource ThemeText3}"
                            Data="M14,3 V13.5 A3,3 0 1 1 12,10.66 V6.5 L20,4.5 V11.5 A3,3 0 1 1 18,8.66 V2 Z"
                            IsVisible="{Binding AlbumArt, Converter={x:Static conv:ObjectConverters.IsNull}}"/>
                </Panel>
              </Border>

              <!-- Title + artist -->
              <StackPanel Spacing="1" VerticalAlignment="Center" MaxWidth="180">
                <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeText}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Artist}" FontSize="10"
                           Foreground="#80b0aaa0" TextTrimming="CharacterEllipsis"/>
              </StackPanel>

              <!-- Controls -->
              <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button Width="26" Height="26" Padding="0" Background="Transparent"
                        BorderThickness="0" Foreground="{DynamicResource ThemeText2}"
                        CornerRadius="13" Cursor="Hand" ToolTip.Tip="Previous"
                        Command="{Binding PrevCommand}">
                  <PathIcon Width="12" Height="12"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Data="M6,5 L6,19 M8,12 L18,5 V19 Z"/>
                </Button>
                <Button Width="30" Height="30" Padding="0"
                        Background="{DynamicResource ThemeAccentSoft}"
                        Foreground="{DynamicResource ThemeAccent}"
                        BorderThickness="0" CornerRadius="15" Cursor="Hand"
                        ToolTip.Tip="Play / Pause"
                        Command="{Binding PlayPauseCommand}">
                  <Panel>
                    <PathIcon Width="12" Height="12"
                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M8,6 H11 V18 H8 Z M13,6 H16 V18 H13 Z"
                              IsVisible="{Binding IsPlaying}"/>
                    <PathIcon Width="12" Height="12"
                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M8,6 V18 L18,12 Z"
                              IsVisible="{Binding !IsPlaying}"/>
                  </Panel>
                </Button>
                <Button Width="26" Height="26" Padding="0" Background="Transparent"
                        BorderThickness="0" Foreground="{DynamicResource ThemeText2}"
                        CornerRadius="13" Cursor="Hand" ToolTip.Tip="Next"
                        Command="{Binding NextCommand}">
                  <PathIcon Width="12" Height="12"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Data="M18,5 L18,19 M6,5 L16,12 L6,19 Z"/>
                </Button>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Thin progress bar at the bottom of the expanded player -->
          <ProgressBar VerticalAlignment="Bottom" Height="2"
                       Minimum="0" Maximum="100"
                       Value="{Binding ProgressPercent}"
                       Background="Transparent"
                       Foreground="{DynamicResource ThemeAccent}"
                       IsVisible="{Binding !IsCollapsed}"/>
        </Panel>
      </Border>

      <!-- ── Search overlay (Ctrl+K) — index.css .search-overlay / .search-hit / .search-esc -->
      <Panel Classes="search-overlay"
             Classes.open="{Binding ShowSearch}"
             IsVisible="{Binding ShowSearch}" ZIndex="300">
        <Border Background="#eb02020c"
                PointerPressed="SearchBackdrop_PointerPressed"/>
        <Grid PointerPressed="ContentCard_PointerPressedNoop">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.2*"/>
            <ColumnDefinition Width="0.6*"/>
            <ColumnDefinition Width="0.2*"/>
          </Grid.ColumnDefinitions>

          <Button Grid.ColumnSpan="3"
                  Classes="search-esc"
                  Content="ESC"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,24,32,0"
                  ZIndex="2"
                  Command="{Binding CloseSearchCommand}"/>

          <StackPanel Grid.Column="1"
                      VerticalAlignment="Top"
                      Margin="0,120,0,0"
                      Spacing="0">
            <Border BorderBrush="#0fffffff" BorderThickness="0,0,0,1"
                    Padding="0,0,0,16">
              <TextBox Text="{Binding SearchQuery}"
                       x:Name="SearchOverlayBox"
                       Watermark="Search your library…"
                       BorderThickness="0" Background="Transparent"
                       Foreground="{DynamicResource ThemeText}"
                       CaretBrush="{DynamicResource ThemeAccent}"
                       FontSize="32" FontWeight="ExtraLight"
                       LetterSpacing="1"
                       HorizontalAlignment="Stretch"
                       HorizontalContentAlignment="Center"
                       Padding="0"
                       AttachedToVisualTree="SearchBox_AttachedToVisualTree"/>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,16,0,0"
                        HorizontalAlignment="Center">
              <Button Classes="search-plat-chip" Content="All"
                      Margin="0,0,5,0"
                      Command="{Binding SetSearchPlatformFilterCommand}"
                      CommandParameter="__all">
                <Button.Background>
                  <MultiBinding Converter="{x:Static conv:SearchChipConverters.Appearance}"
                                ConverterParameter="bg">
                    <Binding Path="SearchPlatformFilter"/>
                    <Binding Source="__all"/>
                  </MultiBinding>
                </Button.Background>
                <Button.Foreground>
                  <MultiBinding Converter="{x:Static conv:SearchChipConverters.Appearance}"
                                ConverterParameter="fg">
                    <Binding Path="SearchPlatformFilter"/>
                    <Binding Source="__all"/>
                  </MultiBinding>
                </Button.Foreground>
                <Button.BorderBrush>
                  <MultiBinding Converter="{x:Static conv:SearchChipConverters.Appearance}"
                                ConverterParameter="border">
                    <Binding Path="SearchPlatformFilter"/>
                    <Binding Source="__all"/>
                  </MultiBinding>
                </Button.BorderBrush>
              </Button>
              <ItemsControl ItemsSource="{Binding SearchActivePlatforms}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Classes="search-plat-chip" Content="{Binding}"
                            Margin="0,0,5,0"
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SetSearchPlatformFilterCommand}"
                            CommandParameter="{Binding}">
                      <Button.Background>
                        <MultiBinding Converter="{x:Static conv:SearchChipConverters.Appearance}"
                                      ConverterParameter="bg">
                          <Binding Path="$parent[Window].((vm:MainViewModel)DataContext).SearchPlatformFilter"/>
                          <Binding/>
                        </MultiBinding>
                      </Button.Background>
                      <Button.Foreground>
                        <MultiBinding Converter="{x:Static conv:SearchChipConverters.Appearance}"
                                      ConverterParameter="fg">
                          <Binding Path="$parent[Window].((vm:MainViewModel)DataContext).SearchPlatformFilter"/>
                          <Binding/>
                        </MultiBinding>
                      </Button.Foreground>
                      <Button.BorderBrush>
                        <MultiBinding Converter="{x:Static conv:SearchChipConverters.Appearance}"
                                      ConverterParameter="border">
                          <Binding Path="$parent[Window].((vm:MainViewModel)DataContext).SearchPlatformFilter"/>
                          <Binding/>
                        </MultiBinding>
                      </Button.BorderBrush>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <ScrollViewer MaxHeight="400" Margin="0,8,0,0"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding SearchResults}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:GameCardViewModel">
                    <Border Padding="10,16" CornerRadius="10" Cursor="Hand"
                            PointerPressed="SearchResult_PointerPressed"
                            Background="{Binding IsSearchHighlighted,
                              Converter={x:Static conv:BoolConverters.IsSearchHighlighted}}">
                      <Border.Styles>
                        <Style Selector="Border:pointerover">
                          <Setter Property="Background" Value="#0bffffff"/>
                        </Style>
                      </Border.Styles>
                      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" Width="40" Height="40"
                                CornerRadius="20" ClipToBounds="True"
                                Background="{DynamicResource ThemeCardUp}"
                                VerticalAlignment="Center">
                          <Panel>
                            <TextBlock Text="{Binding Initial}"
                                       FontSize="14" FontWeight="UltraLight" Foreground="{DynamicResource ThemeText3}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Image Source="{Binding CoverPath}"
                                   IsVisible="{Binding HasCover}"
                                   Stretch="UniformToFill"/>
                          </Panel>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2"
                                    VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="14"
                                     Foreground="{DynamicResource ThemeText}"
                                     TextTrimming="CharacterEllipsis"/>
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding PlatformLabel}"
                                       FontSize="11" Foreground="{DynamicResource ThemeText3}"/>
                            <TextBlock Text="{Binding PlaytimeLabel}"
                                       FontSize="11" Foreground="{DynamicResource ThemeText4}"
                                       IsVisible="{Binding PlaytimeLabel,
                                         Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"/>
                          </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ThemeAccent}" Foreground="{DynamicResource ThemeOnAccent}"
                                FontSize="11" FontWeight="Bold"
                                CornerRadius="6" Padding="10,6"
                                BorderThickness="0" Cursor="Hand"
                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SearchLaunchCommand}"
                                CommandParameter="{Binding}">
                          <PathIcon Width="11" Height="11"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Data="M8,6 V18 L18,12 Z"/>
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <TextBlock IsVisible="{Binding HasNoSearchResults}"
                       Text="No matches"
                       FontSize="13" Foreground="{DynamicResource ThemeText4}"
                       HorizontalAlignment="Center"
                       Margin="0,20"/>
          </StackPanel>
        </Grid>
      </Panel>

    </Panel>

    <!-- Xbox Cloud — true full-window overlay (covers title bar). The panel
         re-implements window controls + drag for use while it's open. -->
    <panels:XcloudPanel x:Name="XcloudPanelHost"
                        Grid.Row="0" Grid.RowSpan="2"
                        ZIndex="1000"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        IsVisible="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsXcloudPanelVisible}"/>

  </Grid>
  </LayoutTransformControl>
</Window>
