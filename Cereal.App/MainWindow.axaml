<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cereal.App.ViewModels"
        xmlns:views="using:Cereal.App.Views"
        xmlns:panels="using:Cereal.App.Views.Panels"
        xmlns:conv="using:Cereal.App"
        x:Class="Cereal.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Cereal"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="#07070d">

  <Window.Styles>
    <!-- Stream tab close button -->
    <Style Selector="Button.tab-close">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="3,0"/>
      <Setter Property="Foreground" Value="#5ab0aaa0"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.tab-close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#22ffffff"/>
      <Setter Property="TextElement.Foreground" Value="#e8e4de"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="40,*">

    <!-- ── Tab bar (title bar region, chrome-extended) ── -->
    <Border Grid.Row="0"
            Background="#cc07070d"
            BorderBrush="#0fffffff"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto">

        <!-- Left: logo -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0"
                    VerticalAlignment="Center" Margin="12,0,0,0">
          <TextBlock Text="⬡" FontSize="18" Foreground="#d4a853"
                     VerticalAlignment="Center" Margin="0,0,6,0"/>
          <TextBlock Text="CEREAL" FontSize="10" FontWeight="Light"
                     LetterSpacing="4" VerticalAlignment="Center"
                     Foreground="#80b0aaa0"/>
        </StackPanel>

        <!-- Center: stream session tabs -->
        <ItemsControl Grid.Column="1" ItemsSource="{Binding StreamTabs}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Margin="8,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="3"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:StreamTabViewModel">
              <Border CornerRadius="6" Padding="8,0,4,0" Height="30"
                      Background="#1affffff">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Title}" Foreground="#e8e4de"
                             FontSize="11" FontWeight="Medium" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding State}" Foreground="#50b0aaa0"
                             FontSize="10" VerticalAlignment="Center"/>
                  <Button Classes="tab-close" Content="×"
                          Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).CloseStreamTabCommand}"
                          CommandParameter="{Binding GameId}"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Right: spacer for OS window controls -->
        <Border Grid.Column="2" Width="140" IsHitTestVisible="False"/>
      </Grid>
    </Border>

    <!-- ── Content: main view + overlay panels ── -->
    <Panel Grid.Row="1">

      <!-- Main library view (always visible) -->
      <views:MainView/>

      <!-- Overlay backdrop (blocks clicks, dims background) -->
      <Border IsVisible="{Binding AnyPanelOpen}"
              Background="#cc07070d"
              IsHitTestVisible="True"
              PointerPressed="Backdrop_PointerPressed"/>

      <!-- Settings panel — slides in from right -->
      <panels:SettingsPanel HorizontalAlignment="Right"
                            Width="480"
                            IsVisible="{Binding ShowSettings}"/>

      <!-- Detect panel -->
      <panels:DetectPanel HorizontalAlignment="Right"
                          Width="520"
                          IsVisible="{Binding ShowDetect}"/>

      <!-- Chiaki panel -->
      <panels:ChiakiPanel HorizontalAlignment="Right"
                          Width="480"
                          IsVisible="{Binding ShowChiaki}"/>

      <!-- Xbox Cloud — full screen -->
      <panels:XcloudPanel IsVisible="{Binding ShowXcloud}"/>

      <!-- Focus panel — full screen game detail (topmost) -->
      <panels:FocusPanel IsVisible="{Binding ShowFocus}"/>

      <!-- ── Stream overlay bar ── -->
      <Border x:Name="StreamBarBorder"
              VerticalAlignment="Top"
              IsVisible="{Binding IsStreaming}"
              Background="#f0101018"
              BorderBrush="#1affffff"
              BorderThickness="0,0,0,1"
              ZIndex="60"
              PointerEntered="StreamBar_PointerEntered"
              PointerExited="StreamBar_PointerExited">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="16,0" Height="38">
          <!-- Dot + title -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center">
            <Ellipse Width="7" Height="7" VerticalAlignment="Center">
              <Ellipse.Fill>
                <SolidColorBrush Color="#22c55e"/>
              </Ellipse.Fill>
            </Ellipse>
            <TextBlock Text="{Binding ActiveStreamTab.Title}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="#e8e4de" VerticalAlignment="Center"/>
          </StackPanel>
          <!-- Platform + state -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center" Margin="12,0">
            <Border CornerRadius="4" Padding="6,2" Background="#18ffffff">
              <TextBlock Text="{Binding ActiveStreamTab.Platform}"
                         FontSize="10" FontWeight="Bold" Foreground="#b0aaa0"/>
            </Border>
            <TextBlock Text="{Binding ActiveStreamTab.State}"
                       FontSize="11" Foreground="#50b0aaa0" VerticalAlignment="Center"/>
          </StackPanel>
          <!-- Fullscreen toggle -->
          <Button Grid.Column="2" x:Name="FullscreenBtn"
                  Width="30" Height="30" Margin="4,0,0,0"
                  VerticalAlignment="Center"
                  Background="Transparent" Foreground="#50b0aaa0"
                  BorderThickness="0" CornerRadius="6" Padding="0"
                  FontSize="12" Cursor="Hand"
                  Click="ToggleFullscreen_Click"
                  ToolTip.Tip="Toggle fullscreen">
            <TextBlock Text="⛶" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Button>
          <!-- Stop button -->
          <Button Grid.Column="4" Content="Stop" Margin="8,0,0,0"
                  VerticalAlignment="Center"
                  Background="#33ff4444" Foreground="#ff7070"
                  BorderThickness="0" CornerRadius="6" Padding="12,4"
                  FontSize="11" Cursor="Hand"
                  Command="{Binding CloseStreamTabCommand}"
                  CommandParameter="{Binding ActiveStreamTab.GameId}"/>
        </Grid>
      </Border>

      <!-- ── Stream connecting spinner ── -->
      <Panel IsVisible="{Binding IsStreamConnecting}"
             IsHitTestVisible="False"
             ZIndex="55">
        <Border Background="#cc07070d"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
          <Border Width="40" Height="40" CornerRadius="20"
                  BorderBrush="#1affffff" BorderThickness="2"
                  HorizontalAlignment="Center">
            <Border.RenderTransform>
              <RotateTransform/>
            </Border.RenderTransform>
            <Border.Transitions>
              <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.8"
                                               Easing="LinearEasing"/>
              </Transitions>
            </Border.Transitions>
          </Border>
          <TextBlock Text="{Binding ActiveStreamTab.State,
                           StringFormat='Connecting — {0}…'}"
                     FontSize="11" Foreground="#50b0aaa0"
                     LetterSpacing="1" HorizontalAlignment="Center"/>
        </StackPanel>
      </Panel>

      <!-- ── Media player widget (bottom-center) ── -->
      <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
              Margin="0,0,0,20"
              IsVisible="{Binding Media.HasMedia}"
              CornerRadius="20"
              Background="#e8101018"
              BorderBrush="#1affffff"
              BorderThickness="1"
              ZIndex="40">
        <StackPanel Orientation="Horizontal" Spacing="0" Margin="6,5">
          <Button Width="30" Height="30" Content="⏮"
                  Background="Transparent" Foreground="#40b0aaa0"
                  BorderThickness="0" Padding="0" Cursor="Hand" FontSize="13"
                  Command="{Binding Media.PrevCommand}"/>
          <StackPanel VerticalAlignment="Center" Spacing="1"
                      MinWidth="80" MaxWidth="200" Margin="8,0">
            <TextBlock Text="{Binding Media.Title}"
                       FontSize="11" FontWeight="Medium" Foreground="#e8e4de"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Media.Artist}"
                       FontSize="10" Foreground="#706b63"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding Media.Artist,
                         Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"/>
          </StackPanel>
          <Button Width="30" Height="30"
                  Background="Transparent" Foreground="#b0aaa0"
                  BorderThickness="0" Padding="0" Cursor="Hand" FontSize="13"
                  Command="{Binding Media.PlayPauseCommand}">
            <Panel>
              <TextBlock Text="▶" FontSize="13"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding !Media.IsPlaying}"/>
              <TextBlock Text="⏸" FontSize="13"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding Media.IsPlaying}"/>
            </Panel>
          </Button>
          <Button Width="30" Height="30" Content="⏭"
                  Background="Transparent" Foreground="#40b0aaa0"
                  BorderThickness="0" Padding="0" Cursor="Hand" FontSize="13"
                  Command="{Binding Media.NextCommand}"/>
        </StackPanel>
      </Border>

      <!-- ── Continue banner (bottom-left) ── -->
      <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
              Margin="20,0,0,20"
              IsVisible="{Binding ShowContinueBanner}"
              CornerRadius="12"
              Background="#e8101018"
              BorderBrush="#1affffff"
              BorderThickness="1"
              ZIndex="50">
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="14,10">
          <StackPanel Spacing="2" VerticalAlignment="Center">
            <TextBlock Text="CONTINUE" FontSize="8" FontWeight="Bold"
                       LetterSpacing="1.5" Foreground="#40b0aaa0"/>
            <TextBlock Text="{Binding ContinueGame.Name}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#e8e4de" MaxWidth="200"
                       TextTrimming="CharacterEllipsis"/>
          </StackPanel>
          <Button Content="▶  Play" VerticalAlignment="Center"
                  Background="#d4a853" Foreground="#07070d"
                  FontSize="11" FontWeight="Bold"
                  CornerRadius="8" Padding="14,7" BorderThickness="0" Cursor="Hand"
                  Command="{Binding LaunchGameCommand}"
                  CommandParameter="{Binding ContinueGame}"/>
          <Button Content="×" VerticalAlignment="Center"
                  Background="Transparent" Foreground="#50b0aaa0"
                  FontSize="16" Width="28" Height="28"
                  CornerRadius="14" Padding="0" BorderThickness="0" Cursor="Hand"
                  Command="{Binding DismissContinueBannerCommand}"/>
        </StackPanel>
      </Border>

      <!-- ── Toast stack (bottom-right) ── -->
      <ItemsControl ItemsSource="{Binding Toasts}"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="0,0,20,20"
                    ZIndex="200">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="8"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ToastViewModel">
            <Border CornerRadius="10" Padding="14,9"
                    Background="#e8101018"
                    BorderBrush="#1affffff"
                    BorderThickness="1">
              <TextBlock Text="{Binding Message}"
                         FontSize="12" Foreground="#b0aaa0"
                         MaxWidth="300" TextWrapping="Wrap"/>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- ── Search overlay (Ctrl+K) ── -->
      <Panel IsVisible="{Binding ShowSearch}" ZIndex="300">
        <!-- Backdrop -->
        <Border Background="#cc07070d"
                PointerPressed="SearchBackdrop_PointerPressed"/>
        <!-- Card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,80,0,0" Width="640" MaxHeight="540"
                CornerRadius="14"
                Background="#e8101018"
                BorderBrush="#1affffff"
                BorderThickness="1"
                ClipToBounds="True"
                PointerPressed="ContentCard_PointerPressedNoop">
          <StackPanel>
            <!-- Search input -->
            <Border Padding="16,12" BorderBrush="#0fffffff" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="⌕" FontSize="18"
                           Foreground="#40b0aaa0" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding SearchQuery}"
                         Watermark="Search games…"
                         BorderThickness="0" Background="Transparent"
                         Foreground="#e8e4de" CaretBrush="#d4a853"
                         FontSize="14" Padding="0"
                         AttachedToVisualTree="SearchBox_AttachedToVisualTree"/>
                <TextBlock Grid.Column="2" Text="ESC" FontSize="10"
                           Foreground="#28b0aaa0" VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
              </Grid>
            </Border>

            <!-- Platform chips (when results span multiple platforms) -->
            <ItemsControl ItemsSource="{Binding SearchActivePlatforms}"
                          Margin="16,10,16,0"
                          IsVisible="{Binding SearchActivePlatforms,
                            Converter={x:Static conv:ObjectConverters.IsNotNull}}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Content="{Binding}" Margin="0,0,6,0" Padding="8,3"
                          FontSize="10" CornerRadius="10" BorderThickness="1"
                          Cursor="Hand"
                          Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SetSearchPlatformFilterCommand}"
                          CommandParameter="{Binding}">
                    <Button.Styles>
                      <Style Selector="Button">
                        <Setter Property="Background" Value="#10ffffff"/>
                        <Setter Property="Foreground" Value="#b0aaa0"/>
                        <Setter Property="BorderBrush" Value="#10ffffff"/>
                      </Style>
                    </Button.Styles>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Results -->
            <ScrollViewer MaxHeight="400" Margin="0,8,0,0"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding SearchResults}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:GameCardViewModel">
                    <Border Padding="16,10" Cursor="Hand"
                            PointerPressed="SearchResult_PointerPressed"
                            Background="{Binding IsSearchHighlighted,
                              Converter={x:Static conv:BoolConverters.IsSearchHighlighted}}">
                      <Border.Styles>
                        <Style Selector="Border:pointerover">
                          <Setter Property="Background" Value="#0cffffff"/>
                        </Style>
                      </Border.Styles>
                      <Grid ColumnDefinitions="44,*,Auto">
                        <!-- Cover thumb -->
                        <Border Grid.Column="0" Width="36" Height="50"
                                CornerRadius="4" ClipToBounds="True"
                                Background="#16161f" VerticalAlignment="Center">
                          <Panel>
                            <TextBlock Text="{Binding Initial}"
                                       FontSize="18" Foreground="#1de8e4de"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Image Source="{Binding CoverPath}"
                                   IsVisible="{Binding HasCover}"
                                   Stretch="UniformToFill"/>
                          </Panel>
                        </Border>
                        <!-- Name + meta -->
                        <StackPanel Grid.Column="1" Spacing="3"
                                    VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="13" FontWeight="SemiBold"
                                     Foreground="#e8e4de"
                                     TextTrimming="CharacterEllipsis"/>
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding PlatformLabel}"
                                       FontSize="11" Foreground="#50b0aaa0"/>
                            <TextBlock Text="{Binding PlaytimeLabel}"
                                       FontSize="11" Foreground="#3d3a35"
                                       IsVisible="{Binding PlaytimeLabel,
                                         Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"/>
                          </StackPanel>
                        </StackPanel>
                        <!-- Launch button -->
                        <Button Grid.Column="2" Content="▶"
                                VerticalAlignment="Center"
                                Background="#d4a853" Foreground="#07070d"
                                FontSize="11" FontWeight="Bold"
                                CornerRadius="6" Padding="10,6"
                                BorderThickness="0" Cursor="Hand"
                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SearchLaunchCommand}"
                                CommandParameter="{Binding}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock IsVisible="{Binding HasNoSearchResults}"
                       Text="No matches"
                       FontSize="13" Foreground="#3d3a35"
                       HorizontalAlignment="Center"
                       Margin="0,20"/>
          </StackPanel>
        </Border>
      </Panel>

    </Panel>

  </Grid>
</Window>
